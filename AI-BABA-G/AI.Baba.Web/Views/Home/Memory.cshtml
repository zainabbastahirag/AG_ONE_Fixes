@{ ViewData["Title"] = "Memory"; Layout = "_PortalLayout"; }
<section class="portal-page">
    <h1>BABA's Memory of You</h1>
    <p class="muted">Long-term facts, preferences, and events BABA recalls in your chats. Stored persistently in SQLite, indexed for vector similarity recall.</p>

    <div class="row-grid">
        <input id="memoryInput" placeholder="e.g. I love mountain hikes. My dog's name is Pixel." />
        <select id="memoryKind">
            <option value="fact">Fact</option>
            <option value="preference">Preference</option>
            <option value="event">Event</option>
        </select>
        <button class="primary" id="memoryAddBtn">Remember</button>
    </div>

    <ul class="mem-list" id="memoryList"></ul>
    <p class="gate" id="memoryGate" hidden>Sign up first to give BABA a memory. <a asp-controller="Home" asp-action="Auth">Create account</a>.</p>
</section>
@section Scripts {
<script>
    const token = localStorage.getItem('baba_token');
    const list = document.getElementById('memoryList');
    const gate = document.getElementById('memoryGate');
    if (!token) { gate.hidden = false; document.getElementById('memoryInput').disabled = true; document.getElementById('memoryAddBtn').disabled = true; }

    async function call(path, opts = {}) {
        const headers = new Headers(opts.headers || {});
        if (token) headers.set('Authorization', 'Bearer ' + token);
        if (opts.body && !headers.has('Content-Type')) headers.set('Content-Type', 'application/json');
        const r = await fetch(path, { ...opts, headers });
        if (!r.ok) throw new Error(r.statusText);
        return r.status === 204 ? null : r.json();
    }
    async function refresh() {
        if (!token) return;
        list.innerHTML = '';
        const items = await call('/api/memory');
        if (!items.length) { list.innerHTML = '<li class="muted" style="background:transparent;border:none">No memories yet — chat with BABA or add one above.</li>'; return; }
        for (const m of items) {
            const li = document.createElement('li');
            li.innerHTML = `
                <span class="kind">${m.kind}</span>
                <div class="body">
                    <div></div>
                    <div class="meta">added ${new Date(m.createdAt).toLocaleDateString()} · used ${m.useCount}× · importance ${(m.importance*100|0)}%</div>
                </div>`;
            li.querySelector('.body div').textContent = m.content;
            const del = document.createElement('button'); del.className='del'; del.textContent='✕';
            del.onclick = async () => { if (!confirm('Forget this?')) return; await call('/api/memory/' + m.id, { method: 'DELETE' }); refresh(); };
            li.appendChild(del);
            list.appendChild(li);
        }
    }
    document.getElementById('memoryAddBtn').addEventListener('click', async () => {
        const v = document.getElementById('memoryInput').value.trim(); if (!v || !token) return;
        await call('/api/memory', { method: 'POST', body: JSON.stringify({ content: v, kind: document.getElementById('memoryKind').value, importance: 0.7 }) });
        document.getElementById('memoryInput').value = ''; refresh();
    });
    if (token) refresh();
</script>
}
