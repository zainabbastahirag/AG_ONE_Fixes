
@page "/"
@inject ResearchApiClient Api
@inject NavigationManager Nav

<PageTitle>Sentiment Sales — Home</PageTitle>
<h1 class="h3-headline">Market Research & Lead Generation</h1>
<p class="body-text-medium-regular">Profile the top 100 LSE-listed companies offshoring IT to India/Asia. Export professional Excel dashboards for digital sales.</p>

<div class="actions-row" style="margin-top:24px">
    <button class="agone-btn-primary-medium" @onclick="StartResearch" disabled="@_busy">@(_busy ? "Running..." : "Start Research (Top 100)")</button>
    <button class="agone-btn-secondary-medium" @onclick="GoDashboard">View Dashboard</button>
    <a class="agone-btn-secondary-medium" href="@Api.GetExcelDownloadUrl()" target="_blank" style="display:inline-flex;align-items:center;text-decoration:none">Download Excel</a>
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <p class="body-text-medium-regular" style="margin-top:16px">@_message</p>
}

@code {
    bool _busy;
    string? _message;
    async Task StartResearch()
    {
        _busy = true;
        _message = null;
        try
        {
            var job = await Api.StartResearchAsync(100);
            _message = job == null ? "Failed to start job." : $"Job {job.JobId} started ({job.Status}). Track progress on Research Jobs.";
        }
        catch (Exception ex) { _message = ex.Message; }
        finally { _busy = false; }
    }
    void GoDashboard() => Nav.NavigateTo("dashboard");
}
