
@page "/research"
@inject ResearchApiClient Api

<PageTitle>Research Jobs</PageTitle>
<h1 class="h4-headline">Research Jobs</h1>
<p class="body-text-medium-regular">Start a job from Home, then poll by Job ID.</p>
<div class="actions-row">
    <input @bind="_jobIdText" placeholder="Job GUID" style="padding:8px;border-radius:6px;border:1px solid #D6DBE6;min-width:320px" />
    <button class="agone-btn-primary-medium" @onclick="LoadJob">Load Status</button>
</div>
@if (_job != null)
{
    <div class="agone-mp-card-metrics-type1" style="margin-top:16px">
        <p><strong>Status:</strong> @_job.Status</p>
        <p><strong>Progress:</strong> @_job.ProcessedCount / @_job.TargetCount</p>
        @if (!string.IsNullOrEmpty(_job.OutputFilePath)) { <p><strong>Output:</strong> @_job.OutputFilePath</p> }
        @if (!string.IsNullOrEmpty(_job.ErrorMessage)) { <p><strong>Error:</strong> @_job.ErrorMessage</p> }
    </div>
}

@code {
    string _jobIdText = "";
    ResearchJobResponse? _job;
    async Task LoadJob() { if (Guid.TryParse(_jobIdText, out var id)) _job = await Api.GetJobAsync(id); }
}
