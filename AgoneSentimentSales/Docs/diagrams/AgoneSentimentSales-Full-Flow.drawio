        <mxCell id="s1" value="1. User POST&#xa;/api/research/start&#xa;{ companyCount: 100 }" style="rounded=1;fillColor=#EBF3FF;strokeColor=#296DF5;" vertex="1" parent="1"><mxGeometry x="60" y="100" width="160" height="70" as="geometry"/></mxCell>
