</style>

@code {
    // ═══ Query param ═══
    [SupplyParameterFromQuery(Name = "userId")]
    public string? PreselectedUserId { get; set; }

    // ═══ Step state ═══
    private int _currentStep = 1;
    private bool _isSubmitting;

    // ═══ Step 1 state ═══
    private List<AssignAccessEntityDto> _entities = new();
    private string _selectedEntityId = "";
    private string _userSearch = "";
    private bool _showUserDropdown;
    private bool _isLoadingUsers;
    private List<AssignAccessUserDto> _allUsers = new();
    private List<AssignAccessUserDto> _selectedUsers = new();

    private List<AssignAccessUserDto> _filteredUsers =>
        string.IsNullOrWhiteSpace(_userSearch)
            ? _allUsers
            : _allUsers.Where(u =>
                u.FullName.Contains(_userSearch, StringComparison.OrdinalIgnoreCase) ||
                u.Email.Contains(_userSearch, StringComparison.OrdinalIgnoreCase))
              .ToList();

    // ═══ Step 2 state ═══
    private List<AssignAccessProductDto> _products = new();
    private List<AssignAccessRoleDto> _allRoles = new();
    private HashSet<Guid> _selectedProductIds = new();
    private Guid? _activeProductId;
    private HashSet<ProductRoleKey> _selectedRoleKeys = new();

    // ═══ Existing roles (for pre-checking) ═══
    private List<ExistingUserRole> _existingRoles = new();

    // ═══ Lifecycle ═══
    protected override async Task OnInitializedAsync()
    {
        await LoadEntities();
        await LoadProducts();
        await LoadRoles();
        await LoadUsers(null);

        // If userId passed via query string, pre-select user and jump to Step 2
        if (Guid.TryParse(PreselectedUserId, out var uid))
        {
            // Try to find user in loaded list first
            var user = _allUsers.FirstOrDefault(u => u.Id == uid);

            // If not in list (e.g. too many users, paginated), fetch directly
            if (user == null)
            {
                try
                {
                    var directUsers = await Http.GetFromJsonAsync<List<AssignAccessUserDto>>($"api/users/access/users?search=") ?? new();
                    user = directUsers.FirstOrDefault(u => u.Id == uid);
                }
                catch { }
            }

            if (user != null)
            {
                _selectedUsers.Add(user);
                await LoadExistingRolesForUser(uid);
                _currentStep = 2;
                StateHasChanged();
            }
        }
    }

    private async Task LoadExistingRolesForUser(Guid userId)
    {
        try
        {
            _existingRoles = await Http.GetFromJsonAsync<List<ExistingUserRole>>($"api/users/{userId}/roles") ?? new();
        }
        catch
        {
            _existingRoles = new();
        }

        // Auto-check products and roles from existing assignments
        foreach (var er in _existingRoles)
        {
            // Determine the product ID: use the role's ProductId, or Guid.Empty for platform roles
            var productId = er.ProductId ?? Guid.Empty;

            // Check the product checkbox
            _selectedProductIds.Add(productId);

            // Check the role checkbox using ProductRoleKey
            _selectedRoleKeys.Add(new ProductRoleKey(productId, er.RoleId));
        }

        // Set the first checked product as the active/visible one on the right panel
        if (_selectedProductIds.Any())
            _activeProductId = _selectedProductIds.First();
    }

    // ═══ Data loading ═══
    private async Task LoadEntities()
    {
        try
        {
            _entities = await Http.GetFromJsonAsync<List<AssignAccessEntityDto>>("api/users/access/entities") ?? new();
        }
        catch
        {
            _entities = new();
        }
    }

    private async Task LoadUsers(Guid? entityId)
    {
        _isLoadingUsers = true;
        StateHasChanged();
        try
        {
            var url = "api/users/access/users";
            var queryParts = new List<string>();
            if (!string.IsNullOrWhiteSpace(_userSearch))
                queryParts.Add($"search={Uri.EscapeDataString(_userSearch)}");
            if (entityId.HasValue)
                queryParts.Add($"entityId={entityId}");
            if (queryParts.Any())
                url += "?" + string.Join("&", queryParts);

            _allUsers = await Http.GetFromJsonAsync<List<AssignAccessUserDto>>(url) ?? new();
        }
        catch
        {
            _allUsers = new();
        }
        finally
        {
            _isLoadingUsers = false;
            StateHasChanged();
        }
    }

    private async Task LoadProducts()
    {
        try
        {
            _products = await Http.GetFromJsonAsync<List<AssignAccessProductDto>>("api/users/access/products") ?? new();
        }
        catch
        {
            _products = new();
        }
    }

    private async Task LoadRoles()
    {
        try
        {
            _allRoles = await Http.GetFromJsonAsync<List<AssignAccessRoleDto>>("api/users/access/roles") ?? new();
        }
        catch
        {
            _allRoles = new();
        }
    }

    // ═══ Step 1 handlers ═══
    private async Task OnEntityChanged(ChangeEventArgs e)
    {
        _selectedEntityId = e.Value?.ToString() ?? "";
        Guid? entityId = Guid.TryParse(_selectedEntityId, out var eid) ? eid : null;
        await LoadUsers(entityId);
    }

    private async Task OnUserSearchKeyUp(KeyboardEventArgs e)
    {
        Guid? entityId = Guid.TryParse(_selectedEntityId, out var eid) ? eid : null;
        await LoadUsers(entityId);
    }

    private void ToggleUserDropdown()
    {
        _showUserDropdown = true;
    }

    private void ToggleUser(AssignAccessUserDto user)
    {
        var existing = _selectedUsers.FirstOrDefault(u => u.Id == user.Id);
        if (existing != null)
            _selectedUsers.Remove(existing);
        else
            _selectedUsers.Add(user);
    }

    private void RemoveUser(AssignAccessUserDto user)
    {
        _selectedUsers.RemoveAll(u => u.Id == user.Id);
    }

    // ═══ Step transitions ═══
    private async Task GoToStep2()
    {
        if (!_selectedUsers.Any()) return;
        if (!_products.Any()) await LoadProducts();
        if (!_allRoles.Any()) await LoadRoles();
        _currentStep = 2;
    }

    private void GoToStep3()
    {
        if (!_selectedRoleKeys.Any()) return;
        _currentStep = 3;
    }

    // ═══ Step 2 handlers ═══
    private void ToggleProduct(Guid productId)
    {
        if (_selectedProductIds.Contains(productId))
        {
            _selectedProductIds.Remove(productId);
            _selectedRoleKeys.RemoveWhere(k => k.ProductId == productId);
        }
        else
        {
            _selectedProductIds.Add(productId);
        }
        _activeProductId = productId;
    }

    private void ToggleRole(ProductRoleKey key)
    {
        if (!_selectedRoleKeys.Remove(key))
            _selectedRoleKeys.Add(key);
    }

    // ═══ Step 3 — Submit ═══
    private async Task SubmitAssignment()
    {
        _isSubmitting = true;
        StateHasChanged();

        try
        {
            var request = new AssignAccessRequest
            {
                UserIds = _selectedUsers.Select(u => u.Id).ToList(),
                Assignments = _selectedRoleKeys.Select(k => new ProductRoleAssignment
                {
                    ProductId = k.ProductId,
                    RoleId = k.RoleId
                }).ToList()
            };

            var response = await Http.PostAsJsonAsync("api/users/access/assign", request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AssignAccessResponse>();
                Snackbar.Add(result?.Message ?? $"Successfully assigned access to {_selectedUsers.Count} user(s)", Severity.Success);
                Nav.NavigateTo("/admin/users");
            }
            else
            {
                var errorBody = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to assign access: {response.StatusCode}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    // ═══ Navigation ═══
    private void NavigateBack()
    {
        Nav.NavigateTo("/admin/users");
    }

    // ═══ Helper record for tracking product + role selections ═══
    private record ProductRoleKey(Guid ProductId, Guid RoleId);

    // ═══ Local DTO references (remove if importing from Shared) ═══
    public class AssignAccessEntityDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
    }

    public class AssignAccessUserDto
    {
        public Guid Id { get; set; }
        public string Email { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string? AvatarUrl { get; set; }
        public string FullName => string.IsNullOrWhiteSpace(FirstName) && string.IsNullOrWhiteSpace(LastName)
            ? Email : $"{FirstName} {LastName}".Trim();
        public string Initials
        {
            get
            {
                var f = FirstName?.Length > 0 ? FirstName[0].ToString().ToUpper() : "";
                var l = LastName?.Length > 0 ? LastName[0].ToString().ToUpper() : "";
                return string.IsNullOrEmpty(f + l) ? (Email.Length > 0 ? Email[..1].ToUpper() : "?") : f + l;
            }
        }
    }

    public class AssignAccessProductDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string Code { get; set; } = "";
    }

    public class AssignAccessRoleDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public string? Description { get; set; }
        public Guid? ProductId { get; set; }
        public bool IsSystemRole { get; set; }
    }

    public class AssignAccessRequest
    {
        public List<Guid> UserIds { get; set; } = new();
        public List<ProductRoleAssignment> Assignments { get; set; } = new();
    }

    public class ProductRoleAssignment
    {
        public Guid ProductId { get; set; }
        public Guid RoleId { get; set; }
    }

    public class AssignAccessResponse
    {
        public bool Success { get; set; }
        public string Message { get; set; } = "";
        public int AssignedCount { get; set; }
        public int SkippedDuplicateCount { get; set; }
    }

    public class ExistingUserRole
    {
        public Guid Id { get; set; }
        public Guid RoleId { get; set; }
        public string RoleName { get; set; } = "";
        public string RoleDisplayName { get; set; } = "";
        public Guid? ProductId { get; set; }
        public string? ProductName { get; set; }
        public int Priority { get; set; }
        public bool IsSystemRole { get; set; }
        public List<string> Permissions { get; set; } = new();
    }
}
