    .rw-form-group label { font-size: 13px; font-weight: 600; color: #374151; }

    .rw-form-group input {
        padding: 10px 14px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: 14px;
    }

    .rw-form-group input:focus {
        outline: none;
        border-color: #4F46E5;
        box-shadow: 0 0 0 3px rgba(79,70,229,0.1);
    }

    .rw-section { margin-bottom: 16px; }
    .rw-section h2 { font-size: 18px; font-weight: 700; color: #0f172a; margin: 0 0 4px; }
    .rw-section p { font-size: 14px; color: #64748b; margin: 0; }

    .rw-access-layout {
        display: flex;
        gap: 0;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        margin-bottom: 24px;
        min-height: 400px;
    }

    .rw-product-list {
        width: 240px;
        min-width: 240px;
        border-right: 1px solid #e2e8f0;
        padding: 16px 0;
    }

    .rw-product-list h3 { font-size: 13px; font-weight: 600; color: #475569; padding: 0 16px; margin: 0 0 12px; }

    .rw-product-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        cursor: pointer;
        font-size: 14px;
        color: #0f172a;
        transition: background 0.15s;
        border-left: 3px solid transparent;
    }

    .rw-product-item:hover { background: #f8fafc; }

    .rw-product-item.active {
        background: #EEF2FF;
        border-left-color: #4F46E5;
        font-weight: 600;
        color: #4F46E5;
    }

    .rw-radio {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        border: 2px solid #d1d5db;
        flex-shrink: 0;
    }

    .rw-radio.checked {
        border-color: #4F46E5;
        background: #4F46E5;
        box-shadow: inset 0 0 0 3px #fff;
    }

    .rw-perm-panel { flex: 1; padding: 16px; overflow-x: auto; }
    .rw-perm-panel h3 { font-size: 13px; font-weight: 600; color: #475569; margin: 0 0 16px; }

    .rw-perm-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 60px 20px;
        color: #94a3b8;
    }

    .rw-perm-empty p { margin: 12px 0 0; font-size: 14px; color: #4F46E5; }

    .rw-matrix-wrap { overflow-x: auto; }

    .rw-matrix { width: 100%; border-collapse: collapse; }
    .rw-matrix thead { background: #4F46E5; }

    .rw-matrix th {
        padding: 10px 16px;
        font-size: 12px;
        font-weight: 700;
        color: #fff;
