</style>

@code {
    [Parameter] public Guid? EditRoleId { get; set; }

    private string _view = "list";
    private string _search = "";
    private Guid? _productFilter;
    private List<RoleListItemDto> _roles = new();
    private List<ProductInfo> _products = new();
    private List<ProductInfo> _allProducts = new();
    private List<ProductPermissionMatrixDto> _permissionMatrix = new();

    // Pagination
    private int _currentPage = 1;
    private int _pageSize = 10;

    // Wizard
    private int _wizardStep = 1;
    private Guid? _editingRoleId;
    private string _formName = "";
    private string? _formDescription;
    private Guid _selectedProductId = Guid.Empty;
    private HashSet<Guid> _selectedPermissions = new();
    private bool _saving;

    private IEnumerable<RoleListItemDto> FilteredRoles => _roles
        .Where(r => _productFilter == null || r.ProductId == _productFilter || r.ProductId == null)
        .Where(r => string.IsNullOrEmpty(_search) || r.DisplayName.Contains(_search, StringComparison.OrdinalIgnoreCase) || (r.Description ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase));

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredRoles.Count() / _pageSize));

    private IEnumerable<RoleListItemDto> PagedRoles => FilteredRoles
        .Skip((_currentPage - 1) * _pageSize)
        .Take(_pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
        await LoadRoles();
        await LoadPermissionMatrix();

        if (Nav.Uri.Contains("/create", StringComparison.OrdinalIgnoreCase))
            StartCreateRole();
        else if (EditRoleId.HasValue)
            await LoadAndEditRole(EditRoleId.Value);
    }

    private async Task LoadProducts()
    {
        try
        {
            var subs = await SubscriptionService.GetMySubscriptionsAsync();
            var prods = await ProductService.GetAllAsync();
            _products = subs.Where(s => s.Status == "Active").Select(s => { var p = prods.FirstOrDefault(x => x.Id == s.ProductId); return new ProductInfo { Id = s.ProductId, Name = p?.Name ?? s.ProductName ?? "Product" }; }).ToList();
            _allProducts = new List<ProductInfo> { new() { Id = Guid.Empty, Name = "AG ONE (admin)" } };
            _allProducts.AddRange(_products);
        }
        catch
        {
            _products = new List<ProductInfo>
            {
                new() { Id = Guid.NewGuid(), Name = "AG ONE Work" },
                new() { Id = Guid.NewGuid(), Name = "AG ONE Learn" },
                new() { Id = Guid.NewGuid(), Name = "AG ONE Safe" },
                new() { Id = Guid.NewGuid(), Name = "AG ONE Pulse" },
                new() { Id = Guid.NewGuid(), Name = "AG ONE SPOT" }
            };
            _allProducts = new List<ProductInfo> { new() { Id = Guid.Empty, Name = "AG ONE (admin)" } };
            _allProducts.AddRange(_products);
        }
    }

    private async Task LoadRoles()
    {
        try { _roles = await Http.GetFromJsonAsync<List<RoleListItemDto>>("api/roles") ?? new(); }
        catch
        {
            _roles = new List<RoleListItemDto>
            {
                new() { Id = Guid.NewGuid(), DisplayName = "Tenant Admin", Description = "Manage tenant settings, users, and permissions.", ProductName = "AG ONE", UserCount = 2 },
                new() { Id = Guid.NewGuid(), DisplayName = "Product Admin", Description = "Manage users, and product master data & configuration", ProductName = "AG ONE Pulse", UserCount = 3 },
                new() { Id = Guid.NewGuid(), DisplayName = "Product Admin", Description = "Manage users, and product master data & configuration", ProductName = "AG ONE Work", UserCount = 1 },
                new() { Id = Guid.NewGuid(), DisplayName = "HR", Description = "Manage employee and HR-related data.", ProductName = "AG ONE Work", UserCount = 7 },
                new() { Id = Guid.NewGuid(), DisplayName = "Hiring Manager", Description = "Oversee hiring tasks and candidate workflows.", ProductName = "AG ONE Pulse", UserCount = 8 },
                new() { Id = Guid.NewGuid(), DisplayName = "L&D", Description = "Manage learning content and training activities.", ProductName = "AG ONE Learn", UserCount = 12 },
                new() { Id = Guid.NewGuid(), DisplayName = "Admin", Description = "Perform system and user compliance administration.", ProductName = "AG ONE Safe", UserCount = 10 },
            };
        }
        _currentPage = 1;
    }

    private async Task LoadPermissionMatrix()
    {
        try { _permissionMatrix = await Http.GetFromJsonAsync<List<ProductPermissionMatrixDto>>("api/roles/permissions/matrix") ?? new(); }
        catch
        {
            _permissionMatrix = new List<ProductPermissionMatrixDto>
            {
                new() { ProductId = Guid.Empty, ProductName = "AG ONE (admin)", Groups = new()
                {
                    new() { GroupName = "User Management", Rows = new() { new() { Resource = "Users", CreateId = Guid.NewGuid(), ReadId = Guid.NewGuid(), UpdateId = Guid.NewGuid(), DeleteId = Guid.NewGuid() }, new() { Resource = "Roles", CreateId = Guid.NewGuid(), ReadId = Guid.NewGuid(), UpdateId = Guid.NewGuid(), DeleteId = Guid.NewGuid() }, new() { Resource = "Permissions", CreateId = Guid.NewGuid(), ReadId = Guid.NewGuid(), UpdateId = Guid.NewGuid(), DeleteId = Guid.NewGuid() } } },
                    new() { GroupName = "Tenant Management", Rows = new() { new() { Resource = "Tenant Information", CreateId = Guid.NewGuid(), ReadId = Guid.NewGuid(), UpdateId = Guid.NewGuid(), DeleteId = Guid.NewGuid() }, new() { Resource = "Subscriptions", CreateId = Guid.NewGuid(), ReadId = Guid.NewGuid(), UpdateId = Guid.NewGuid(), DeleteId = Guid.NewGuid() }, new() { Resource = "Billing", CreateId = Guid.NewGuid(), ReadId = Guid.NewGuid(), UpdateId = Guid.NewGuid(), DeleteId = Guid.NewGuid() } } }
                } }
            };
        }
    }

    private void OnProductFilterChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        _productFilter = string.IsNullOrEmpty(val) ? null : Guid.TryParse(val, out var id) ? id : null;
        _currentPage = 1;
    }

    private void GoToPage(int page) { _currentPage = page; }
    private void PreviousPage() { if (_currentPage > 1) _currentPage--; }
    private void NextPage() { if (_currentPage < TotalPages) _currentPage++; }

    private void StartCreateRole() { _view = "wizard"; _wizardStep = 1; _editingRoleId = null; _formName = ""; _formDescription = null; _selectedProductId = Guid.Empty; _selectedPermissions.Clear(); }

    private async Task StartEditRole(Guid roleId) { await LoadAndEditRole(roleId); }

    private async Task LoadAndEditRole(Guid roleId)
    {
        try
        {
            var detail = await Http.GetFromJsonAsync<RoleDetailDto>($"api/roles/{roleId}");
            if (detail != null)
            {
                _editingRoleId = detail.Id;
                _formName = detail.DisplayName;
                _formDescription = detail.Description;
                _selectedProductId = detail.ProductId ?? Guid.Empty;
                _selectedPermissions = detail.PermissionIds.ToHashSet();
                _view = "wizard";
                _wizardStep = 1;
            }
        }
        catch
        {
            _editingRoleId = roleId;
            _formName = _roles.FirstOrDefault(r => r.Id == roleId)?.DisplayName ?? "";
            _formDescription = _roles.FirstOrDefault(r => r.Id == roleId)?.Description;
            _view = "wizard";
            _wizardStep = 1;
        }
    }

    private void BackToList() { _view = "list"; _editingRoleId = null; }
    private void SelectProduct(Guid pid) { _selectedProductId = pid; }
    private bool IsPermSelected(Guid? permId) => permId.HasValue && _selectedPermissions.Contains(permId.Value);
    private void TogglePerm(Guid? permId) { if (!permId.HasValue) return; if (!_selectedPermissions.Remove(permId.Value)) _selectedPermissions.Add(permId.Value); }

    private string GetSelectedProductNames()
    {
        if (_selectedProductId == Guid.Empty) return "AG ONE (admin)";
        return _allProducts.FirstOrDefault(p => p.Id == _selectedProductId)?.Name ?? "—";
    }

    private string? FindPermission(Guid permId)
    {
        foreach (var m in _permissionMatrix)
            foreach (var g in m.Groups)
                foreach (var r in g.Rows)
                {
                    if (r.CreateId == permId) return $"{r.Resource}:Create";
                    if (r.ReadId == permId) return $"{r.Resource}:Read";
                    if (r.UpdateId == permId) return $"{r.Resource}:Update";
                    if (r.DeleteId == permId) return $"{r.Resource}:Delete";
                }
        return null;
    }

    private string GetProductColor(string? name) => (name ?? "").ToLower() switch
    {
        var n when n.Contains("work") => "c-green",
        var n when n.Contains("learn") => "c-purple",
        var n when n.Contains("safe") => "c-cyan",
        var n when n.Contains("pulse") => "c-yellow",
        var n when n.Contains("spot") => "c-pink",
        _ => "c-blue"
    };

    private async Task SaveRole()
    {
        _saving = true; StateHasChanged();
        try
        {
            if (_editingRoleId.HasValue)
            {
                await Http.PutAsJsonAsync($"api/roles/{_editingRoleId}", new { Id = _editingRoleId, Name = _formName, Description = _formDescription, ProductAccessIds = new List<Guid> { _selectedProductId }, PermissionIds = _selectedPermissions.ToList() });
                Snackbar.Add("Role updated", Severity.Success);
            }
            else
            {
                await Http.PostAsJsonAsync("api/roles", new { Name = _formName, Description = _formDescription, ProductAccessIds = new List<Guid> { _selectedProductId }, PermissionIds = _selectedPermissions.ToList() });
                Snackbar.Add("Role created", Severity.Success);
            }
            await LoadRoles();
            BackToList();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _saving = false; StateHasChanged(); }
    }

    private class ProductInfo { public Guid Id { get; set; } public string Name { get; set; } = ""; }

    public class RoleListItemDto { public Guid Id { get; set; } public string DisplayName { get; set; } = ""; public string? Description { get; set; } public Guid? ProductId { get; set; } public string? ProductName { get; set; } public bool IsSystemRole { get; set; } public int UserCount { get; set; } }
    public class RoleDetailDto { public Guid Id { get; set; } public string DisplayName { get; set; } = ""; public string? Description { get; set; } public Guid? ProductId { get; set; } public List<Guid> PermissionIds { get; set; } = new(); }
    public class ProductPermissionMatrixDto { public Guid ProductId { get; set; } public string ProductName { get; set; } = ""; public List<PermissionGroupMatrixDto> Groups { get; set; } = new(); }
    public class PermissionGroupMatrixDto { public string GroupName { get; set; } = ""; public List<PermissionRowDto> Rows { get; set; } = new(); }
    public class PermissionRowDto { public string Resource { get; set; } = ""; public Guid? CreateId { get; set; } public Guid? ReadId { get; set; } public Guid? UpdateId { get; set; } public Guid? DeleteId { get; set; } }
}
