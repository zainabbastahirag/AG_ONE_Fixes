@page "/admin/roles"
@page "/admin/roles/create"
@page "/admin/roles/edit/{EditRoleId:guid}"
@layout AdminLayout
@inject HttpClient Http
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ISubscriptionService SubscriptionService
@inject IProductService ProductService

<PageTitle>Roles - AGOne</PageTitle>

@if (_view == "list")
{
    <div class="rl-page">
        <!-- Page Header -->
        <div class="rl-page-header">
            <div>
                <h1 class="rl-page-title">Roles</h1>
                <p class="rl-page-subtitle">Manage roles and access for users</p>
            </div>
            <button class="rl-btn-add" @onclick="StartCreateRole">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14" /><path d="M12 5v14" />
                </svg>
                Create Role
            </button>
        </div>

        <!-- Body: Sidebar + Content -->
        <div class="rl-body">
            <!-- Left Sidebar: Product Navigator -->
            <aside class="rl-sidebar">
                <div class="rl-sidebar-title">Product Navigator</div>

                <div class="rl-sidebar-group">
                    <button class="rl-sidebar-group-toggle expanded">
                        <span class="rl-sidebar-group-name">Products</span>
                        <svg class="rl-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m6 9 6 6 6-6" />
                        </svg>
                    </button>
                    <ul class="rl-sidebar-list">
                        <li class="rl-sidebar-item @(_productFilter == null ? "active" : "")"
                            @onclick="@(() => _productFilter = null)">
                            All Products
                        </li>
                        @foreach (var p in _products)
                        {
                            <li class="rl-sidebar-item @(_productFilter == p.Id ? "active" : "")"
                                @onclick="@(() => _productFilter = p.Id)">
                                @p.Name
                            </li>
                        }
                    </ul>
                </div>
            </aside>

            <!-- Main Content -->
            <div class="rl-main">
                <!-- Filter Row -->
                <div class="rl-filters">
                    <div class="rl-filter-group">
                        <label class="rl-filter-label">Product</label>
                        <div class="rl-dropdown">
                            <span class="rl-dropdown-value">@(_productFilter == null ? "All Products" : _products.FirstOrDefault(p => p.Id == _productFilter)?.Name ?? "All Products")</span>
                            <button class="rl-dropdown-clear" @onclick="@(() => _productFilter = null)" title="Clear">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M18 6 6 18" /><path d="m6 6 12 12" />
                                </svg>
                            </button>
                            <select class="rl-dropdown-select" @onchange="OnProductFilterChanged">
                                <option value="">All Products</option>
                                @foreach (var p in _products)
                                {
                                    <option value="@p.Id" selected="@(_productFilter == p.Id)">@p.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Search + Refresh -->
                <div class="rl-search-row">
                    <div class="rl-search-box">
                        <svg class="rl-search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" />
                        </svg>
                        <input type="text" class="rl-search-input" placeholder="Search" @bind="_search" @bind:event="oninput" />
                    </div>
                    <button class="rl-refresh-btn" @onclick="LoadRoles" title="Refresh">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8" />
                            <path d="M21 3v5h-5" />
                            <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16" />
                            <path d="M8 16H3v5" />
                        </svg>
                    </button>
                </div>

                <!-- Data Table -->
                <div class="rl-table-wrapper">
                    <table class="rl-table">
                        <thead>
                            <tr>
                                <th class="col-role">Role</th>
                                <th class="col-desc">Description</th>
                                <th class="col-product">Product</th>
                                <th class="col-users">Users</th>
                                <th class="col-action">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!PagedRoles.Any())
                            {
                                <tr>
                                    <td colspan="5" class="rl-empty-row">No roles found</td>
                                </tr>
                            }
                            @foreach (var role in PagedRoles)
                            {
                                <tr>
                                    <td class="col-role"><span class="rl-role-name">@role.DisplayName</span></td>
                                    <td class="col-desc rl-desc-text">@(role.Description ?? "—")</td>
                                    <td class="col-product">
                                        <span class="rl-product-badge @GetProductColor(role.ProductName)">@(role.ProductName ?? "AG ONE")</span>
                                    </td>
                                    <td class="col-users">@role.UserCount</td>
                                    <td class="col-action">
                                        <button class="rl-edit-btn" title="Edit" @onclick="@(() => StartEditRole(role.Id))">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" />
                                                <path d="m15 5 4 4" />
                                            </svg>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Table Footer -->
                @if (FilteredRoles.Any())
                {
                    <div class="rl-table-footer">
                        <span class="rl-showing-text">Showing @((_currentPage - 1) * _pageSize + 1) to @(Math.Min(_currentPage * _pageSize, FilteredRoles.Count())) of @FilteredRoles.Count() entries</span>
                        <div class="rl-pagination">
                            <button class="rl-page-btn" disabled="@(_currentPage <= 1)" @onclick="PreviousPage">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="m15 18-6-6 6-6" />
                                </svg>
                            </button>
                            @for (int p = 1; p <= TotalPages; p++)
                            {
                                var pageNum = p;
                                <button class="rl-page-num @(pageNum == _currentPage ? "active" : "")" @onclick="@(() => GoToPage(pageNum))">@pageNum</button>
                            }
                            <button class="rl-page-btn" disabled="@(_currentPage >= TotalPages)" @onclick="NextPage">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="m9 18 6-6-6-6" />
                                </svg>
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}
else
{
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- CREATE / EDIT ROLE WIZARD                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <div class="rw-page">
        <button class="rw-back" @onclick="BackToList">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m12 19-7-7 7-7" /><path d="M19 12H5" /></svg>
            Back to Roles
        </button>

        <!-- Stepper -->
        <div class="rw-stepper">
            <div class="rw-step @(_wizardStep == 1 ? "active" : _wizardStep > 1 ? "done" : "")">
                <div class="rw-step-circle">1</div>
                <span>General</span>
            </div>
            <div class="rw-step-line @(_wizardStep > 1 ? "done" : "")"></div>
            <div class="rw-step @(_wizardStep == 2 ? "active" : "")">
                <div class="rw-step-circle">2</div>
                <span>Review</span>
            </div>
        </div>

        @if (_wizardStep == 1)
        {
            <!-- Step 1: General -->
            <div class="rw-card">
                <div class="rw-form-row">
                    <div class="rw-form-group">
                        <label>Role Name</label>
                        <input type="text" @bind="_formName" placeholder="E.g Content Editor, Team Lead" />
                    </div>
                    <div class="rw-form-group">
                        <label>Description</label>
                        <input type="text" @bind="_formDescription" placeholder="Describe this role" />
                    </div>
                </div>
            </div>

            <div class="rw-section">
                <h2>Product Access</h2>
                <p>Choose which products this user will have access to and assign role</p>
            </div>

            <div class="rw-access-layout">
                <!-- Left: Product Selector -->
                <div class="rw-product-list">
                    <h3>Select Products</h3>
                    @foreach (var p in _allProducts)
                    {
                        <div class="rw-product-item @(_selectedProductId == p.Id ? "active" : "")" @onclick="() => SelectProduct(p.Id)">
                            <div class="rw-radio @(_selectedProductId == p.Id ? "checked" : "")"></div>
                            <span>@p.Name</span>
                        </div>
                    }
                </div>

                <!-- Right: Permission Matrix -->
                <div class="rw-perm-panel">
                    <h3>Select Role's Permissions</h3>
                    @if (_selectedProductId == Guid.Empty)
                    {
                        <div class="rw-perm-empty">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" /><polyline points="14 2 14 8 20 8" /><circle cx="15" cy="13" r="1" fill="#cbd5e1" stroke="none" /></svg>
                            <p>Select product on the left to assign role</p>
                        </div>
                    }
                    else
                    {
                        var matrix = _permissionMatrix.FirstOrDefault(m => m.ProductId == _selectedProductId);
                        if (matrix != null)
                        {
                            <div class="rw-matrix-wrap">
                                <table class="rw-matrix">
                                    <thead>
                                        <tr>
                                            <th class="rw-m-role">Role</th>
                                            <th class="rw-m-action">Create</th>
                                            <th class="rw-m-action">Read</th>
                                            <th class="rw-m-action">Update</th>
                                            <th class="rw-m-action">Delete</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var group in matrix.Groups)
                                        {
                                            <tr class="rw-m-group-row">
                                                <td colspan="5">@group.GroupName</td>
                                            </tr>
                                            @foreach (var row in group.Rows)
                                            {
                                                <tr>
                                                    <td class="rw-m-resource">@row.Resource</td>
                                                    <td class="rw-m-check"><input type="checkbox" checked="@IsPermSelected(row.CreateId)" @onchange="() => TogglePerm(row.CreateId)" disabled="@(row.CreateId == null)" /></td>
                                                    <td class="rw-m-check"><input type="checkbox" checked="@IsPermSelected(row.ReadId)" @onchange="() => TogglePerm(row.ReadId)" disabled="@(row.ReadId == null)" /></td>
                                                    <td class="rw-m-check"><input type="checkbox" checked="@IsPermSelected(row.UpdateId)" @onchange="() => TogglePerm(row.UpdateId)" disabled="@(row.UpdateId == null)" /></td>
                                                    <td class="rw-m-check"><input type="checkbox" checked="@IsPermSelected(row.DeleteId)" @onchange="() => TogglePerm(row.DeleteId)" disabled="@(row.DeleteId == null)" /></td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="rw-perm-empty"><p>No permissions defined for this product.</p></div>
                        }
                    }
                </div>
            </div>

            <div class="rw-nav">
                <button class="rw-btn-outline" @onclick="BackToList">Cancel</button>
                <button class="rl-btn-add" @onclick="() => _wizardStep = 2" disabled="@(string.IsNullOrWhiteSpace(_formName))">
                    Next
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6" /></svg>
                </button>
            </div>
        }
        else
        {
            <!-- Step 2: Review -->
            <div class="rw-card">
                <h3>Review Role</h3>
                <div class="rw-review-grid">
                    <div class="rw-review-item"><span class="rw-review-label">Role Name</span><span class="rw-review-value">@_formName</span></div>
                    <div class="rw-review-item"><span class="rw-review-label">Description</span><span class="rw-review-value">@(_formDescription ?? "—")</span></div>
                    <div class="rw-review-item"><span class="rw-review-label">Products</span><span class="rw-review-value">@GetSelectedProductNames()</span></div>
                    <div class="rw-review-item"><span class="rw-review-label">Permissions</span><span class="rw-review-value">@_selectedPermissions.Count selected</span></div>
                </div>

                @if (_selectedPermissions.Any())
                {
                    <h4 style="margin-top:20px;">Selected Permissions</h4>
                    <div class="rw-review-perms">
                        @foreach (var permId in _selectedPermissions)
                        {
                            var perm = FindPermission(permId);
                            if (perm != null)
                            {
                                <span class="rw-perm-chip">@perm</span>
                            }
                        }
                    </div>
                }
            </div>

            <div class="rw-nav">
                <button class="rw-btn-outline" @onclick="() => _wizardStep = 1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6" /></svg>
                    Back
                </button>
                <button class="rl-btn-add" @onclick="SaveRole" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="rl-spinner"></span>
                    }
                    @(_editingRoleId.HasValue ? "Update Role" : "Create Role")
                </button>
            </div>
        }
    </div>
}

<style>
    /* ===== Page Layout ===== */
    .rl-page {
        display: flex;
        flex-direction: column;
        height: 100%;
        font-family: 'Inter', 'Segoe UI', sans-serif;
    }

    .rl-page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 24px;
    }

    .rl-page-title {
        font-size: 24px;
        font-weight: 700;
        color: #111827;
        margin: 0 0 4px 0;
    }

    .rl-page-subtitle {
        font-size: 14px;
        color: #6B7280;
        margin: 0;
    }

    .rl-btn-add {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 20px;
        background: #1e3a5f;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.2s;
    }

    .rl-btn-add:hover { background: #163050; }
    .rl-btn-add:disabled { opacity: 0.5; cursor: not-allowed; }

    /* ===== Body: Sidebar + Main ===== */
    .rl-body {
        display: flex;
        gap: 24px;
        flex: 1;
        min-height: 0;
    }

    /* ===== Sidebar ===== */
    .rl-sidebar {
        width: 220px;
        min-width: 220px;
        background: #fff;
        border-right: 1px solid #E5E7EB;
        padding: 0 16px 16px 0;
    }

    .rl-sidebar-title {
        font-size: 14px;
        font-weight: 600;
        color: #374151;
        padding: 12px 0;
        border-bottom: 1px solid #E5E7EB;
        margin-bottom: 4px;
    }

    .rl-sidebar-group-toggle {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        background: none;
        border: none;
        padding: 10px 0;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        color: #4F46E5;
        transition: color 0.15s;
    }

    .rl-sidebar-group-toggle:hover { color: #3730A3; }

    .rl-chevron { transition: transform 0.2s; }
    .rl-sidebar-group-toggle.expanded .rl-chevron { transform: rotate(180deg); }

    .rl-sidebar-list {
        list-style: none;
        margin: 0;
        padding: 0 0 4px 0;
    }

    .rl-sidebar-item {
        padding: 8px 12px;
        font-size: 13px;
        color: #374151;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.15s;
        border-left: 3px solid transparent;
    }

    .rl-sidebar-item:hover { background: #F3F4F6; }

    .rl-sidebar-item.active {
        background: #4F46E5;
        color: #fff;
        border-left-color: #4F46E5;
        font-weight: 500;
    }

    /* ===== Main Content ===== */
    .rl-main {
        flex: 1;
        min-width: 0;
    }

    /* ===== Filter Dropdowns ===== */
    .rl-filters {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
    }

    .rl-filter-group {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .rl-filter-label {
        font-size: 12px;
        font-weight: 500;
        color: #6B7280;
    }

    .rl-dropdown {
        position: relative;
        display: flex;
        align-items: center;
        background: #fff;
        border: 1px solid #D1D5DB;
        border-radius: 8px;
        padding: 8px 12px;
        gap: 8px;
        min-width: 200px;
        cursor: pointer;
    }

    .rl-dropdown-value {
        font-size: 14px;
        color: #111827;
        flex: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .rl-dropdown-clear {
        display: flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        padding: 2px;
        cursor: pointer;
        color: #9CA3AF;
        border-radius: 4px;
        transition: color 0.15s;
    }

    .rl-dropdown-clear:hover { color: #374151; }

    .rl-dropdown-select {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
        width: 100%;
        height: 100%;
    }

    /* ===== Search Row ===== */
    .rl-search-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }

    .rl-search-box {
        position: relative;
        flex: 0 1 340px;
    }

    .rl-search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #9CA3AF;
        pointer-events: none;
    }

    .rl-search-input {
        width: 100%;
        padding: 9px 12px 9px 36px;
        border: 1px solid #D1D5DB;
        border-radius: 8px;
        font-size: 14px;
        color: #111827;
        background: #fff;
        outline: none;
        transition: border-color 0.15s;
    }

    .rl-search-input::placeholder { color: #9CA3AF; }
    .rl-search-input:focus { border-color: #4F46E5; }

    .rl-refresh-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        background: #fff;
        border: 1px solid #D1D5DB;
        border-radius: 8px;
        cursor: pointer;
        color: #6B7280;
        transition: all 0.15s;
    }

    .rl-refresh-btn:hover {
        border-color: #4F46E5;
        color: #4F46E5;
    }

    /* ===== Data Table ===== */
    .rl-table-wrapper {
        border: 1px solid #E5E7EB;
        border-radius: 10px;
        overflow: hidden;
        background: #fff;
    }

    .rl-table {
        width: 100%;
        border-collapse: collapse;
    }

    .rl-table thead tr { background: #4F46E5; }

    .rl-table thead th {
        padding: 12px 16px;
        font-size: 13px;
        font-weight: 600;
        color: #fff;
        text-align: left;
        white-space: nowrap;
    }

    .rl-table thead th.col-users { width: 80px; }
    .rl-table thead th.col-action { width: 70px; text-align: center; }

    .rl-table tbody tr {
        border-bottom: 1px solid #F3F4F6;
        transition: background 0.1s;
    }

    .rl-table tbody tr:last-child { border-bottom: none; }
    .rl-table tbody tr:hover { background: #F9FAFB; }

    .rl-table tbody td {
        padding: 12px 16px;
        font-size: 14px;
        color: #374151;
    }

    .rl-table tbody td.col-action { text-align: center; }

    .rl-empty-row {
        text-align: center;
        padding: 48px 16px !important;
        color: #94a3b8;
    }

    .rl-role-name {
        font-weight: 600;
        color: #111827;
    }

    .rl-desc-text {
        color: #6B7280;
        max-width: 300px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* ===== Product Badges ===== */
    .rl-product-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    .rl-product-badge.c-blue { background: #dbeafe; color: #1d4ed8; }
    .rl-product-badge.c-purple { background: #ede9fe; color: #6d28d9; }
    .rl-product-badge.c-green { background: #dcfce7; color: #16a34a; }
    .rl-product-badge.c-yellow { background: #fef3c7; color: #d97706; }
    .rl-product-badge.c-pink { background: #fce7f3; color: #db2777; }
    .rl-product-badge.c-cyan { background: #cffafe; color: #0891b2; }

    /* ===== Edit Button ===== */
    .rl-edit-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: none;
        border: 1px solid #D1D5DB;
        border-radius: 6px;
        color: #6B7280;
        cursor: pointer;
        transition: all 0.15s;
    }

    .rl-edit-btn:hover {
        border-color: #4F46E5;
        color: #4F46E5;
        background: #EEF2FF;
    }

    /* ===== Table Footer ===== */
    .rl-table-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 0 0 0;
    }

    .rl-showing-text {
        font-size: 13px;
        color: #6B7280;
    }

    .rl-pagination {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .rl-page-btn {
        display: flex;
