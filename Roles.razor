    /* Card */
    .rw-card {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 24px;
    }

    .rw-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }

    .rw-field { display: flex; flex-direction: column; gap: 6px; }

    .rw-label { font-size: 13px; font-weight: 600; color: #374151; }

    .rw-input {
        padding: 10px 14px;
        border: 1px solid #d1d5db;
