    .rw-input::placeholder { color: #9CA3AF; }
    .rw-input:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,0.1); }

    /* Section Header */
    .rw-section-header { margin-bottom: 16px; }
    .rw-section-header h2 { font-size: 18px; font-weight: 700; color: #0f172a; margin: 0 0 4px; }
    .rw-section-header p { font-size: 14px; color: #64748b; margin: 0; }

    /* Access Layout */
    .rw-access-layout {
        display: flex;
        gap: 0;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        margin-bottom: 24px;
        min-height: 400px;
    }

    .rw-products-panel {
        width: 260px;
        min-width: 260px;
        border-right: 1px solid #e2e8f0;
        padding: 20px 0;
    }

    .rw-panel-title { font-size: 13px; font-weight: 600; color: #475569; padding: 0 20px; margin: 0 0 16px; }

    .rw-product-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        cursor: pointer;
        font-size: 14px;
        color: #0f172a;
        border: 1px solid transparent;
        margin: 0 12px 6px;
        border-radius: 8px;
        transition: all 0.15s;
    }

    .rw-product-row:hover { background: #f8fafc; border-color: #e2e8f0; }

    .rw-product-row.selected {
        background: #eff6ff;
        border-color: #93c5fd;
        font-weight: 600;
        color: #1d4ed8;
    }

    .rw-radio {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 2px solid #d1d5db;
        flex-shrink: 0;
        transition: all 0.15s;
    }

    .rw-radio.checked {
        border-color: #3b82f6;
        background: #3b82f6;
        box-shadow: inset 0 0 0 3px #fff;
    }

    /* Permissions Panel */
    .rw-perms-panel { flex: 1; padding: 20px; overflow-x: auto; }

    .rw-perms-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 20px;
        color: #94a3b8;
    }

    .rw-perms-empty p { margin: 16px 0 0; font-size: 14px; color: #3b82f6; }

    /* Permission Matrix */
    .rw-matrix-wrap { overflow-x: auto; }
    .rw-matrix { width: 100%; border-collapse: collapse; }

    .rw-matrix thead tr { background: #3b82f6; }

    .rw-matrix th {
        padding: 10px 16px;
        font-size: 12px;
        font-weight: 700;
        color: #fff;
        text-align: center;
    }

    .rw-matrix th.rw-m-role { text-align: left; }

    .rw-matrix td { padding: 10px 16px; border-bottom: 1px solid #f1f5f9; font-size: 14px; }

    .rw-m-group { background: #f1f5f9; }
    .rw-m-group td { font-weight: 700; color: #475569; font-size: 13px; }
    .rw-m-resource { color: #0f172a; }
    .rw-m-check { text-align: center; }
    .rw-m-check input { width: 18px; height: 18px; accent-color: #3b82f6; cursor: pointer; }
    .rw-m-check input:disabled { opacity: 0.6; cursor: default; accent-color: #3b82f6; }
    .rw-m-check input:checked { accent-color: #3b82f6; }
    .rw-m-check input:checked:disabled { accent-color: #3b82f6; opacity: 0.8; }
    .rw-m-act { text-align: center; }

    /* Wizard Footer */
    .rw-footer {
        display: flex;
        justify-content: center;
        gap: 16px;
        margin-top: 8px;
    }

    .rw-btn-back {
        flex: 1;
        max-width: 400px;
        padding: 12px 24px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        background: #fff;
        color: #374151;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        text-align: center;
        transition: background 0.15s;
    }

    .rw-btn-back:hover { background: #f9fafb; }

    .rw-btn-next {
        flex: 1;
        max-width: 400px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 12px 24px;
        background: #3b82f6;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

    .rw-btn-next:hover { background: #2563eb; }
    .rw-btn-next:disabled { opacity: 0.5; cursor: not-allowed; }

    .rw-btn-confirm {
        flex: 1;
        max-width: 400px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 12px 24px;
        background: linear-gradient(90deg, #4F46E5, #7C3AED);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    .rw-btn-confirm:hover { opacity: 0.9; }
    .rw-btn-confirm:disabled { opacity: 0.5; cursor: not-allowed; }

    /* Review Step */
    .rw-review-meta {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-bottom: 20px;
        padding-bottom: 20px;
        border-bottom: 1px solid #f1f5f9;
    }

    .rw-review-row { display: flex; flex-direction: column; gap: 4px; }
    .rw-review-label { font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; }
    .rw-review-value { font-size: 15px; font-weight: 500; color: #0f172a; }

    .rw-review-group { margin-bottom: 4px; }

    .rw-review-group-header {
        background: #f1f5f9;
        padding: 10px 16px;
        font-size: 14px;
        font-weight: 700;
        color: #374151;
        border-radius: 6px;
        margin-bottom: 2px;
    }

    .rw-review-perm-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 16px;
        border-bottom: 1px solid #f8fafc;
    }

    .rw-review-resource { font-size: 14px; color: #0f172a; }

    .rw-review-chips { display: flex; gap: 6px; flex-wrap: wrap; }

    .rw-chip {
        padding: 4px 12px;
        border: 1px solid #3b82f6;
        color: #3b82f6;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        background: #fff;
    }

    .rw-review-empty { font-size: 14px; color: #94a3b8; text-align: center; padding: 20px 0; }

    .rw-spinner {
        width: 16px;
        height: 16px;
        border: 2px solid rgba(255,255,255,0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: rw-spin 0.6s linear infinite;
        display: inline-block;
    }

    @@keyframes rw-spin { to { transform: rotate(360deg); } }

    @@media (max-width: 768px) {
        .rw-access-layout { flex-direction: column; }
        .rw-products-panel { width: 100%; min-width: 100%; border-right: none; border-bottom: 1px solid #e2e8f0; }
        .rw-form-row { grid-template-columns: 1fr; }
        .rw-footer { flex-direction: column; }
        .rw-btn-back, .rw-btn-next, .rw-btn-confirm { max-width: 100%; }
    }
</style>

@code {
    [Parameter] public Guid? EditRoleId { get; set; }

    private string _view = "list";
    private string _search = "";
    private Guid? _productFilter;
    private List<RoleListItemDto> _roles = new();
    private List<ProductInfo> _products = new();
    private List<ProductInfo> _allProducts = new();
    private List<ProductPermissionMatrixDto> _permissionMatrix = new();

    private int _currentPage = 1;
    private int _pageSize = 10;

    private int _wizardStep = 1;
    private Guid? _editingRoleId;
    private string _formName = "";
    private string? _formDescription;
    private Guid? _selectedProductId;
    private HashSet<Guid> _selectedPermissions = new();
    private bool _saving;
    private bool _isViewOnly;

    private IEnumerable<RoleListItemDto> FilteredRoles => _roles
        .Where(r => _productFilter == null || r.ProductId == _productFilter || r.ProductId == null)
        .Where(r => string.IsNullOrEmpty(_search) || r.DisplayName.Contains(_search, StringComparison.OrdinalIgnoreCase) || (r.Description ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase));

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredRoles.Count() / _pageSize));

    private IEnumerable<RoleListItemDto> PagedRoles => FilteredRoles
        .Skip((_currentPage - 1) * _pageSize)
        .Take(_pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
        await LoadRoles();
        await LoadPermissionMatrix();

        if (Nav.Uri.Contains("/create", StringComparison.OrdinalIgnoreCase))
            StartCreateRole();
        else if (EditRoleId.HasValue)
            await LoadAndEditRole(EditRoleId.Value);
    }

    private async Task LoadProducts()
    {
        try
        {
            var subs = await SubscriptionService.GetMySubscriptionsAsync();
            var prods = await ProductService.GetAllAsync();
            _products = subs.Where(s => s.Status == "Active")
                .Select(s =>
                {
                    var p = prods.FirstOrDefault(x => x.Id == s.ProductId);
                    return new ProductInfo { Id = s.ProductId, Name = p?.Name ?? s.ProductName ?? "Product" };
                }).ToList();
        }
        catch
        {
            _products = new();
        }
    }

    private async Task LoadRoles()
    {
        try { _roles = await Http.GetFromJsonAsync<List<RoleListItemDto>>("api/roles") ?? new(); }
        catch { _roles = new(); }
        _currentPage = 1;
    }

    private async Task LoadPermissionMatrix()
    {
        try
        {
            _permissionMatrix = await Http.GetFromJsonAsync<List<ProductPermissionMatrixDto>>("api/roles/permissions/matrix") ?? new();
        }
        catch
        {
            _permissionMatrix = new();
        }

        _allProducts = _permissionMatrix
            .Select(m => new ProductInfo { Id = m.ProductId, Name = m.ProductName })
            .ToList();

        if (!_products.Any() && _allProducts.Any())
        {
            _products = _allProducts.ToList();
        }
    }

    private void PreviousPage() { if (_currentPage > 1) _currentPage--; }
    private void NextPage() { if (_currentPage < TotalPages) _currentPage++; }

    private void StartCreateRole()
    {
        _view = "wizard";
        _wizardStep = 1;
        _editingRoleId = null;
        _formName = "";
        _formDescription = null;
        _selectedProductId = null;
        _selectedPermissions.Clear();
        _isViewOnly = false;
    }

    private async Task StartEditRole(Guid roleId) { await LoadAndEditRole(roleId); }

    private async Task LoadAndEditRole(Guid roleId)
    {
        try
        {
            var detail = await Http.GetFromJsonAsync<RoleDetailDto>($"api/roles/{roleId}");
            if (detail != null)
            {
                _editingRoleId = detail.Id;
                _formName = detail.DisplayName;
                _formDescription = detail.Description;
                _selectedProductId = detail.ProductId;
                _selectedPermissions = detail.PermissionIds.ToHashSet();
                _isViewOnly = detail.IsSystemRole;
                _view = "wizard";
                _wizardStep = 1;
                return;
            }
        }
        catch { }

        var fallbackRole = _roles.FirstOrDefault(r => r.Id == roleId);
        _editingRoleId = roleId;
        _formName = fallbackRole?.DisplayName ?? "";
        _formDescription = fallbackRole?.Description;
        _selectedProductId = null;
        _isViewOnly = fallbackRole?.IsSystemRole == true;
        _view = "wizard";
        _wizardStep = 1;
    }

    private void BackToList() { _view = "list"; _editingRoleId = null; _selectedProductId = null; _isViewOnly = false; }

    private void SelectProduct(Guid pid) { _selectedProductId = pid; }

    private bool IsPermSelected(Guid? permId) => permId.HasValue && _selectedPermissions.Contains(permId.Value);

    private void TogglePerm(Guid? permId)
    {
        if (!permId.HasValue) return;
        if (!_selectedPermissions.Remove(permId.Value))
            _selectedPermissions.Add(permId.Value);
    }

    private string GetSelectedProductNames()
    {
        if (_selectedProductId == null) return "—";
        return _allProducts.FirstOrDefault(p => p.Id == _selectedProductId.Value)?.Name ?? "—";
    }

    private ProductPermissionMatrixDto? GetDeduplicatedMatrix(Guid productId)
    {
        var raw = _permissionMatrix.FirstOrDefault(m => m.ProductId == productId);
        if (raw == null) return null;

        return new ProductPermissionMatrixDto
        {
            ProductId = raw.ProductId,
            ProductName = raw.ProductName,
            Groups = raw.Groups.Select(g => new PermissionGroupMatrixDto
            {
                GroupName = g.GroupName,
                Rows = g.Rows
                    .GroupBy(r => r.Resource)
                    .Select(grp => grp.First())
                    .ToList()
            }).ToList()
        };
    }

    private string? FindPermission(Guid permId)
    {
        foreach (var m in _permissionMatrix)
            foreach (var g in m.Groups)
                foreach (var r in g.Rows)
                {
                    if (r.CreateId == permId) return $"{r.Resource}:Create";
                    if (r.ReadId == permId) return $"{r.Resource}:Read";
                    if (r.UpdateId == permId) return $"{r.Resource}:Update";
                    if (r.DeleteId == permId) return $"{r.Resource}:Delete";
                }
        return null;
    }

    private List<ReviewPermRow> GetGroupSelectedPermissions(PermissionGroupMatrixDto group)
    {
        var result = new List<ReviewPermRow>();
        var seen = new HashSet<string>();

        foreach (var row in group.Rows)
        {
            if (!seen.Add(row.Resource)) continue;
            var actions = new List<string>();
            if (row.CreateId.HasValue && _selectedPermissions.Contains(row.CreateId.Value)) actions.Add("Create");
            if (row.ReadId.HasValue && _selectedPermissions.Contains(row.ReadId.Value)) actions.Add("Read");
            if (row.UpdateId.HasValue && _selectedPermissions.Contains(row.UpdateId.Value)) actions.Add("Update");
            if (row.DeleteId.HasValue && _selectedPermissions.Contains(row.DeleteId.Value)) actions.Add("Delete");
            if (actions.Any())
                result.Add(new ReviewPermRow { Resource = row.Resource, Actions = actions });
        }
        return result;
    }

    private string GetProductColor(string? name) => (name ?? "").ToLower() switch
    {
        var n when n.Contains("work") => "c-green",
        var n when n.Contains("learn") => "c-purple",
        var n when n.Contains("safe") => "c-cyan",
        var n when n.Contains("pulse") => "c-yellow",
        var n when n.Contains("spot") => "c-pink",
        _ => "c-blue"
    };

    private async Task SaveRole()
    {
        _saving = true; StateHasChanged();
        try
        {
            var productId = _selectedProductId ?? Guid.Empty;
            if (_editingRoleId.HasValue)
            {
                await Http.PutAsJsonAsync($"api/roles/{_editingRoleId}", new { Id = _editingRoleId, Name = _formName, Description = _formDescription, ProductAccessIds = new List<Guid> { productId }, PermissionIds = _selectedPermissions.ToList() });
                Snackbar.Add("Role updated", Severity.Success);
            }
            else
            {
                await Http.PostAsJsonAsync("api/roles", new { Name = _formName, Description = _formDescription, ProductAccessIds = new List<Guid> { productId }, PermissionIds = _selectedPermissions.ToList() });
                Snackbar.Add("Role created", Severity.Success);
            }
            await LoadRoles();
            BackToList();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _saving = false; StateHasChanged(); }
    }

    private class ProductInfo { public Guid Id { get; set; } public string Name { get; set; } = ""; }
    private class ReviewPermRow { public string Resource { get; set; } = ""; public List<string> Actions { get; set; } = new(); }

    public class RoleListItemDto { public Guid Id { get; set; } public string DisplayName { get; set; } = ""; public string? Description { get; set; } public Guid? ProductId { get; set; } public string? ProductName { get; set; } public bool IsSystemRole { get; set; } public int UserCount { get; set; } }
    public class RoleDetailDto { public Guid Id { get; set; } public string DisplayName { get; set; } = ""; public string? Description { get; set; } public Guid? ProductId { get; set; } public bool IsSystemRole { get; set; } public List<Guid> PermissionIds { get; set; } = new(); }
    public class ProductPermissionMatrixDto { public Guid ProductId { get; set; } public string ProductName { get; set; } = ""; public List<PermissionGroupMatrixDto> Groups { get; set; } = new(); }
    public class PermissionGroupMatrixDto { public string GroupName { get; set; } = ""; public List<PermissionRowDto> Rows { get; set; } = new(); }
    public class PermissionRowDto { public string Resource { get; set; } = ""; public Guid? CreateId { get; set; } public Guid? ReadId { get; set; } public Guid? UpdateId { get; set; } public Guid? DeleteId { get; set; } }
}
