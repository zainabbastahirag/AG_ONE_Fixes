    }

    .rw-m-group-row { background: #f1f5f9; }
    .rw-m-group-row td { font-weight: 700; color: #475569; font-size: 13px; }
    .rw-m-resource { color: #0f172a; }
    .rw-m-check { text-align: center; }

    .rw-m-check input { width: 18px; height: 18px; accent-color: #4F46E5; cursor: pointer; }
    .rw-m-check input:disabled { opacity: 0.2; cursor: default; }
    .rw-m-action { text-align: center; }

    .rw-nav {
        display: flex;
        justify-content: space-between;
        margin-top: 8px;
    }

    .rw-btn-outline {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 20px;
        border: 1px solid #d1d5db;
