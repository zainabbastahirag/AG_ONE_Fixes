@page "/admin/masterdatatenant"
@layout AdminLayout
@inject ISubscriptionService SubscriptionService
@inject IProductService ProductService
@inject IAuthService AuthService
@inject IAGAuthorizationService AuthorizationService
@inject ITenantMasterDataApiService TenantMasterDataService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Master Data - AGOne</PageTitle>

<div class="mdt-page">
    <!-- Page Header -->
    <div class="mdt-page-header">
        <div class="mdt-page-header-left">
            <h1 class="mdt-page-title">Master Data</h1>
            <p class="mdt-page-subtitle">Manage organizational master data including departments, locations, and cost centers</p>
        </div>
        <button class="mdt-btn-add-values" @onclick="OpenAddModal">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14" /><path d="M12 5v14" />
            </svg>
            Add Values
        </button>
    </div>

    <!-- Body: Sidebar + Content -->
    <div class="mdt-body">
        <!-- Left Sidebar: Field Navigator -->
        <aside class="mdt-sidebar">
            <div class="mdt-sidebar-title">Field Navigator</div>

            @foreach (var group in _sidebarGroups)
            {
                <div class="mdt-sidebar-group">
                    <button class="mdt-sidebar-group-toggle @(group.IsExpanded ? "expanded" : "")"
                            @onclick="@(() => ToggleSidebarGroup(group))">
                        <span class="mdt-sidebar-group-name">@group.GroupName</span>
                        <svg class="mdt-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m6 9 6 6 6-6" />
                        </svg>
                    </button>

                    @if (group.IsExpanded)
                    {
                        <ul class="mdt-sidebar-list">
                            @foreach (var entity in group.Entities)
                            {
                                <li class="mdt-sidebar-item @(_selectedEntityCode == entity.EntityCode ? "active" : "")"
                                    @onclick="@(() => SelectSidebarEntity(entity))">
                                    @entity.EntityName
                                </li>
                            }
                        </ul>
                    }
                </div>
            }
        </aside>

        <!-- Main Content -->
        <div class="mdt-main">
            <!-- Filter Row: Scope + Product dropdowns -->
            <div class="mdt-filters">
                <div class="mdt-filter-group">
                    <label class="mdt-filter-label">Scope</label>
                    <div class="mdt-dropdown">
                        <span class="mdt-dropdown-value">@(_selectedScope == "global" ? "Global" : "Product")</span>
                        <button class="mdt-dropdown-clear" @onclick="@(() => SelectScope("global"))" title="Clear">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 6 6 18" /><path d="m6 6 12 12" />
                            </svg>
                        </button>
                        <select class="mdt-dropdown-select" value="@_selectedScope" @onchange="OnScopeChanged">
                            <option value="global">Global</option>
                            <option value="product">Product</option>
                        </select>
                    </div>
                </div>

                @if (_selectedScope == "product")
                {
                    <div class="mdt-filter-group">
                        <label class="mdt-filter-label">Product</label>
                        <div class="mdt-dropdown product-dropdown">
                            <span class="mdt-dropdown-value">@GetSelectedProductName()</span>
                            <button class="mdt-dropdown-clear" title="Clear">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M18 6 6 18" /><path d="m6 6 12 12" />
                                </svg>
                            </button>
                            <select class="mdt-dropdown-select" value="@_selectedProductId" @onchange="OnProductChanged">
                                @foreach (var product in _subscribedProducts)
                                {
                                    <option value="@product.ProductId">@product.ProductName</option>
                                }
                            </select>
                        </div>
                    </div>
                }
            </div>

            <!-- Search + Refresh -->
            <div class="mdt-search-row">
                <div class="mdt-search-box">
                    <svg class="mdt-search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" />
                    </svg>
                    <input type="text" class="mdt-search-input" placeholder="Search" @bind="_searchQuery" @bind:event="oninput" />
                </div>
                <button class="mdt-refresh-btn" @onclick="RefreshData" title="Refresh">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8" />
                        <path d="M21 3v5h-5" />
                        <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16" />
                        <path d="M8 16H3v5" />
                    </svg>
                </button>
            </div>

            <!-- Data Table -->
            @if (_isLoading || _isLoadingData)
            {
                <div class="mdt-loading">
                    <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
                    <span>Loading...</span>
                </div>
            }
            else if (FilteredItems.Count == 0)
            {
                <div class="mdt-empty-state">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
                        <polyline points="14 2 14 8 20 8" />
                        <line x1="16" x2="8" y1="13" y2="13" /><line x1="16" x2="8" y1="17" y2="17" />
                        <line x1="10" x2="8" y1="9" y2="9" />
                    </svg>
                    <h4>No data found</h4>
                    <p>Start by adding a new value or import from a file.</p>
                </div>
            }
            else
            {
                <div class="mdt-table-wrapper">
                    <table class="mdt-table">
                        <thead>
                            <tr>
                                <th class="col-id">ID</th>
                                @foreach (var field in _currentFields.Where(f => f.ShowInList).OrderBy(f => f.DisplayOrder))
                                {
                                    <th>@field.FieldName</th>
                                }
                                <th class="col-type">Type</th>
                                <th class="col-status">Status</th>
                                <th class="col-action">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var pageItems = GetPagedItems(); var rowIdx = (_currentPage - 1) * _pageSize; }
                            @foreach (var item in pageItems)
                            {
                                rowIdx++;
                                <tr>
                                    <td class="col-id">@GetItemCode(item, rowIdx)</td>
                                    @foreach (var field in _currentFields.Where(f => f.ShowInList).OrderBy(f => f.DisplayOrder))
                                    {
                                        <td>@GetFieldDisplayValue(item.FieldValues, field)</td>
                                    }
                                    <td class="col-type mdt-type-text">Single select dropdown</td>
                                    <td class="col-status">
                                        <label class="mdt-toggle">
                                            <input type="checkbox" checked="@IsItemActive(item)" @onchange="@((ChangeEventArgs e) => ToggleItemStatus(item, e))" />
                                            <span class="mdt-toggle-slider"></span>
                                        </label>
                                    </td>
                                    <td class="col-action">
                                        <button class="mdt-edit-btn" title="Edit" @onclick="@(() => OpenEditModal(item))">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" />
                                                <path d="m15 5 4 4" />
                                            </svg>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Table Footer -->
                <div class="mdt-table-footer">
                    <span class="mdt-showing-text">Showing @((_currentPage - 1) * _pageSize + 1) to @(Math.Min(_currentPage * _pageSize, FilteredItems.Count)) of @FilteredItems.Count entries</span>
                    <div class="mdt-pagination">
                        <button class="mdt-page-btn" disabled="@(_currentPage <= 1)" @onclick="PreviousPage">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="m15 18-6-6 6-6" />
                            </svg>
                        </button>
                        @for (int p = 1; p <= TotalPages; p++)
                        {
                            var pageNum = p;
                            <button class="mdt-page-num @(pageNum == _currentPage ? "active" : "")" @onclick="@(() => GoToPage(pageNum))">@pageNum</button>
                        }
                        <button class="mdt-page-btn" disabled="@(_currentPage >= TotalPages)" @onclick="NextPage">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="m9 18 6-6-6-6" />
                            </svg>
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
@if (_showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-container" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(_isEditMode ? "Edit" : "Add New") @GetSelectedEntityName()</h3>
                <button class="modal-close-btn" @onclick="CloseModal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 6 6 18M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div class="modal-body">
                <MudForm @ref="_form" @bind-IsValid="_formIsValid">
                    <MudGrid>
                        @foreach (var field in _currentFields.Where(f => f.ShowInForm).OrderBy(f => f.DisplayOrder))
                        {
                            <MudItem xs="12" sm="@(field.DataType.ToLower() == "boolean" || field.DataType.ToLower() == "bool" ? 12 : 6)">
                                @switch (field.DataType.ToLower())
                                {
                                    case "string":
                                    case "text":
                                        <MudTextField T="string"
                                                      Value="GetFieldValue<string>(field.FieldCode)"
                                                      ValueChanged="@((string val) => SetFieldValue(field.FieldCode, val))"
                                                      Label="@field.FieldName"
                                                      HelperText="@field.FieldDescription"
                                                      Required="@field.IsRequired"
                                                      RequiredError="@($"{field.FieldName} is required")"
                                                      MaxLength="@(field.MaxLength ?? 500)"
                                                      ReadOnly="@field.IsReadOnly"
                                                      Variant="Variant.Outlined"
                                                      Class="mb-3" />
                                        break;
                                    case "int":
                                    case "integer":
                                        <MudNumericField T="int?"
                                                         Value="GetFieldValue<int?>(field.FieldCode)"
                                                         ValueChanged="@((int? val) => SetFieldValue(field.FieldCode, val))"
                                                         Label="@field.FieldName"
                                                         HelperText="@field.FieldDescription"
                                                         Required="@field.IsRequired"
                                                         RequiredError="@($"{field.FieldName} is required")"
                                                         ReadOnly="@field.IsReadOnly"
                                                         Variant="Variant.Outlined"
                                                         Class="mb-3" />
                                        break;
                                    case "decimal":
                                    case "money":
                                    case "currency":
                                    case "number":
                                        <MudNumericField T="decimal?"
                                                         Value="GetFieldValue<decimal?>(field.FieldCode)"
                                                         ValueChanged="@((decimal? val) => SetFieldValue(field.FieldCode, val))"
                                                         Label="@field.FieldName"
                                                         HelperText="@field.FieldDescription"
                                                         Required="@field.IsRequired"
                                                         RequiredError="@($"{field.FieldName} is required")"
                                                         ReadOnly="@field.IsReadOnly"
                                                         Variant="Variant.Outlined"
                                                         Class="mb-3" />
                                        break;
                                    case "bool":
                                    case "boolean":
                                        <MudCheckBox T="bool"
                                                     Value="GetFieldValue<bool>(field.FieldCode)"
                                                     ValueChanged="@((bool val) => SetFieldValue(field.FieldCode, val))"
                                                     Label="@field.FieldName"
                                                     ReadOnly="@field.IsReadOnly"
                                                     Color="Color.Primary"
                                                     Class="mb-3" />
                                        break;
                                    case "date":
                                        <MudDatePicker Date="@GetFieldDateValue(field.FieldCode)"
                                                       DateChanged="@((DateTime? val) => SetFieldValue(field.FieldCode, val))"
                                                       Label="@field.FieldName"
                                                       HelperText="@field.FieldDescription"
                                                       Required="@field.IsRequired"
                                                       RequiredError="@($"{field.FieldName} is required")"
                                                       ReadOnly="@field.IsReadOnly"
                                                       Variant="Variant.Outlined"
                                                       Editable="true"
                                                       DateFormat="yyyy-MM-dd"
                                                       PickerVariant="PickerVariant.Dialog"
                                                       Class="mb-3" />
                                        break;
                                    case "datetime":
                                        <MudDatePicker Date="@GetFieldDateValue(field.FieldCode)"
                                                       DateChanged="@((DateTime? val) => SetFieldValue(field.FieldCode, val))"
                                                       Label="@field.FieldName"
                                                       HelperText="@field.FieldDescription"
                                                       Required="@field.IsRequired"
                                                       RequiredError="@($"{field.FieldName} is required")"
                                                       ReadOnly="@field.IsReadOnly"
                                                       Variant="Variant.Outlined"
                                                       Editable="true"
                                                       DateFormat="yyyy-MM-dd HH:mm"
                                                       PickerVariant="PickerVariant.Dialog"
                                                       Class="mb-3" />
                                        break;
                                    case "lookup":
                                    default:
                                        <MudTextField T="string"
                                                      Value="GetFieldValue<string>(field.FieldCode)"
                                                      ValueChanged="@((string val) => SetFieldValue(field.FieldCode, val))"
                                                      Label="@field.FieldName"
                                                      HelperText="@field.FieldDescription"
                                                      Required="@field.IsRequired"
                                                      RequiredError="@($"{field.FieldName} is required")"
                                                      ReadOnly="@field.IsReadOnly"
                                                      Variant="Variant.Outlined"
                                                      Class="mb-3" />
                                        break;
                                }
                            </MudItem>
                        }
                    </MudGrid>
                </MudForm>
            </div>
            <div class="modal-footer">
                <MudButton OnClick="CloseModal" Variant="Variant.Text">Cancel</MudButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveItem" Disabled="@(!_formIsValid || _isSaving)">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @(_isEditMode ? "Update" : "Add")
                </MudButton>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
@if (_showDeleteConfirm)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-container delete-confirm" @onclick:stopPropagation="true">
            <div class="modal-header delete">
                <h3>Confirm Delete</h3>
                <button class="modal-close-btn" @onclick="CancelDelete">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M18 6 6 18M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="delete-confirm-content">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none"
                         stroke="#f44336" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10" /><path d="M12 8v4" /><path d="m12 16 .01 0" />
                    </svg>
                    <p>Are you sure you want to delete <strong>@_deleteItemName</strong>?</p>
                    <p class="text-muted">This action cannot be undone.</p>
                </div>
            </div>
            <div class="modal-footer">
                <MudButton OnClick="CancelDelete" Variant="Variant.Text">Cancel</MudButton>
                <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="ConfirmDelete">Delete</MudButton>
            </div>
        </div>
    </div>
}

<style>
    /* ===== Page Layout ===== */
    .mdt-page {
        display: flex;
        flex-direction: column;
        height: 100%;
        font-family: 'Inter', 'Segoe UI', sans-serif;
    }

    .mdt-page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 24px;
    }

    .mdt-page-title {
        font-size: 24px;
        font-weight: 700;
        color: #111827;
        margin: 0 0 4px 0;
    }

    .mdt-page-subtitle {
        font-size: 14px;
        color: #6B7280;
        margin: 0;
    }

    .mdt-btn-add-values {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 10px 20px;
        background: #1e3a5f;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.2s;
    }

    .mdt-btn-add-values:hover {
        background: #163050;
    }

    /* ===== Body: Sidebar + Main ===== */
    .mdt-body {
        display: flex;
        gap: 24px;
        flex: 1;
        min-height: 0;
    }

    /* ===== Sidebar ===== */
    .mdt-sidebar {
        width: 220px;
        min-width: 220px;
        background: #fff;
        border-right: 1px solid #E5E7EB;
        padding: 0 16px 16px 0;
    }

    .mdt-sidebar-title {
        font-size: 14px;
        font-weight: 600;
        color: #374151;
        padding: 12px 0 12px 0;
        border-bottom: 1px solid #E5E7EB;
        margin-bottom: 4px;
    }

    .mdt-sidebar-group {
        margin-bottom: 0;
    }

    .mdt-sidebar-group-toggle {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        background: none;
        border: none;
        padding: 10px 0;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        color: #4F46E5;
        transition: color 0.15s;
    }

    .mdt-sidebar-group-toggle:hover {
        color: #3730A3;
    }

    .mdt-chevron {
        transition: transform 0.2s;
    }

    .mdt-sidebar-group-toggle.expanded .mdt-chevron {
        transform: rotate(180deg);
    }

    .mdt-sidebar-list {
        list-style: none;
        margin: 0;
        padding: 0 0 4px 0;
    }

    .mdt-sidebar-item {
        padding: 8px 12px;
        font-size: 13px;
        color: #374151;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.15s;
        border-left: 3px solid transparent;
    }

    .mdt-sidebar-item:hover {
        background: #F3F4F6;
    }

    .mdt-sidebar-item.active {
        background: #4F46E5;
        color: #fff;
        border-left-color: #4F46E5;
        font-weight: 500;
    }

    /* ===== Main Content ===== */
    .mdt-main {
        flex: 1;
        min-width: 0;
    }

    /* ===== Filter Dropdowns ===== */
    .mdt-filters {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
    }

    .mdt-filter-group {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .mdt-filter-label {
        font-size: 12px;
        font-weight: 500;
        color: #6B7280;
    }

    .mdt-dropdown {
        position: relative;
        display: flex;
        align-items: center;
        background: #fff;
        border: 1px solid #D1D5DB;
        border-radius: 8px;
        padding: 8px 12px;
        gap: 8px;
        min-width: 160px;
        cursor: pointer;
    }

    .mdt-dropdown.product-dropdown {
        min-width: 220px;
    }

    .mdt-dropdown-value {
        font-size: 14px;
        color: #111827;
        flex: 1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .mdt-dropdown-clear {
        display: flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        padding: 2px;
        cursor: pointer;
        color: #9CA3AF;
        border-radius: 4px;
        transition: color 0.15s;
    }

    .mdt-dropdown-clear:hover {
        color: #374151;
    }

    .mdt-dropdown-select {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
        width: 100%;
        height: 100%;
    }

    /* ===== Search Row ===== */
    .mdt-search-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }

    .mdt-search-box {
        position: relative;
        flex: 0 1 340px;
    }

    .mdt-search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #9CA3AF;
        pointer-events: none;
    }

    .mdt-search-input {
        width: 100%;
        padding: 9px 12px 9px 36px;
        border: 1px solid #D1D5DB;
        border-radius: 8px;
        font-size: 14px;
        color: #111827;
        background: #fff;
        outline: none;
        transition: border-color 0.15s;
    }

    .mdt-search-input::placeholder {
        color: #9CA3AF;
    }

    .mdt-search-input:focus {
        border-color: #4F46E5;
    }

    .mdt-refresh-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        background: #fff;
        border: 1px solid #D1D5DB;
        border-radius: 8px;
        cursor: pointer;
        color: #6B7280;
        transition: all 0.15s;
    }

    .mdt-refresh-btn:hover {
        border-color: #4F46E5;
        color: #4F46E5;
    }

    /* ===== Data Table ===== */
    .mdt-table-wrapper {
        border: 1px solid #E5E7EB;
        border-radius: 10px;
        overflow: hidden;
        background: #fff;
    }

    .mdt-table {
        width: 100%;
        border-collapse: collapse;
    }

    .mdt-table thead tr {
        background: #4F46E5;
    }

    .mdt-table thead th {
        padding: 12px 16px;
        font-size: 13px;
        font-weight: 600;
        color: #fff;
        text-align: left;
        white-space: nowrap;
    }

    .mdt-table thead th.col-id {
        width: 100px;
    }

    .mdt-table thead th.col-type {
        width: 200px;
    }

    .mdt-table thead th.col-status {
        width: 80px;
        text-align: center;
    }

    .mdt-table thead th.col-action {
        width: 70px;
        text-align: center;
    }

    .mdt-table tbody tr {
        border-bottom: 1px solid #F3F4F6;
