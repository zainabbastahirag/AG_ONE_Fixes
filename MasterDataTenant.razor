@code {
    // State
    private string _selectedScope = "product";
    private Guid _selectedProductId = Guid.Empty;
    private string _selectedEntityCode = "";
    private Guid _selectedMasterDataDefId = Guid.Empty;
    private int _currentPage = 1;
    private int _pageSize = 10;
    private bool _isLoading = true;
    private bool _isLoadingData = false;
    private string _searchQuery = "";

    // Data
    private List<SubscribedProductViewModel> _subscribedProducts = new();
    private List<TenantMasterDataItemDto> _masterDataItems = new();
    private List<MasterDataDefinitionWithFieldsDto> _entityTabs = new();
    private List<MasterDataFieldDto> _currentFields = new();
    private ProductMasterDataSchemaDto? _currentSchema;

    // Sidebar
    private List<SidebarGroup> _sidebarGroups = new();

    // Modal state
    private bool _showModal = false;
    private bool _isEditMode = false;
    private bool _formIsValid = false;
    private bool _isSaving = false;
    private MudForm? _form;
    private EditItemModel _editItem = new();

    // Delete confirmation state
    private bool _showDeleteConfirm = false;
    private TenantMasterDataItemDto? _itemToDelete = null;
    private string _deleteItemName = "";

    // Computed
    private List<TenantMasterDataItemDto> FilteredItems
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_searchQuery))
                return _masterDataItems;

            var q = _searchQuery.Trim().ToLower();
            return _masterDataItems.Where(item =>
                item.FieldValues != null &&
                item.FieldValues.Values.Any(v => v?.ToString()?.ToLower().Contains(q) == true)
            ).ToList();
        }
    }

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredItems.Count / _pageSize));

    protected override async Task OnInitializedAsync()
    {
        await LoadSubscribedProductsAsync();
    }

    private async Task LoadSubscribedProductsAsync()
    {
        _isLoading = true;
        try
        {
            var subscriptions = await SubscriptionService.GetMySubscriptionsAsync();
            var products = await ProductService.GetAllAsync();

            foreach (var sub in subscriptions.Where(s => s.Status == "Active"))
            {
                var product = products.FirstOrDefault(p => p.Id == sub.ProductId);
                if (product != null)
                {
                    _subscribedProducts.Add(new SubscribedProductViewModel
                    {
                        ProductId = sub.ProductId,
                        ProductCode = product.Code ?? "",
                        ProductName = product.Name
                    });
                }
            }

            if (_subscribedProducts.Any())
            {
                _selectedProductId = _subscribedProducts.First().ProductId;
                await LoadProductSchemaAsync();
            }
        }
        catch
        {
            _subscribedProducts = new List<SubscribedProductViewModel>
            {
                new() { ProductId = Guid.Parse("22222222-2222-2222-2222-222222222222"), ProductCode = "AGOneWork", ProductName = "AG ONE Work" },
                new() { ProductId = Guid.NewGuid(), ProductCode = "AGOneLearn", ProductName = "AG ONE Learn" }
            };
            _selectedProductId = _subscribedProducts.First().ProductId;
            await LoadProductSchemaAsync();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadProductSchemaAsync()
    {
        if (_selectedProductId == Guid.Empty) return;

        _isLoading = true;
        StateHasChanged();

        try
        {
            _currentSchema = await TenantMasterDataService.GetProductSchemaAsync(_selectedProductId);

            if (_currentSchema != null && _currentSchema.Definitions.Any())
            {
                _entityTabs = _currentSchema.Definitions;
                BuildSidebarGroups();

                var firstDef = _entityTabs.First();
                _selectedEntityCode = firstDef.EntityCode;
                _selectedMasterDataDefId = firstDef.MasterDataDefId;
                _currentFields = firstDef.Fields;

                await LoadDataItemsAsync();
            }
            else
            {
                _entityTabs = new();
                _masterDataItems = new();
                BuildSidebarGroups();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading schema: {ex.Message}");
            LoadSampleSchema();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void BuildSidebarGroups()
    {
        _sidebarGroups = new List<SidebarGroup>();

        var grouped = _entityTabs
            .GroupBy(e => e.GroupName ?? "General")
            .OrderBy(g => g.Key);

        foreach (var grp in grouped)
        {
            _sidebarGroups.Add(new SidebarGroup
            {
                GroupName = grp.Key,
                IsExpanded = true,
                Entities = grp.OrderBy(e => e.DisplayOrder).ToList()
            });
        }

        if (!_sidebarGroups.Any() && _entityTabs.Any())
        {
            _sidebarGroups.Add(new SidebarGroup
            {
                GroupName = "Employee Info",
                IsExpanded = true,
                Entities = _entityTabs.OrderBy(e => e.DisplayOrder).ToList()
            });
        }
    }

    private void LoadSampleSchema()
    {
        _entityTabs = new List<MasterDataDefinitionWithFieldsDto>
        {
            new() { MasterDataDefId = Guid.NewGuid(), EntityCode = "GENDER", EntityName = "Gender", GroupName = "Employee Info", DisplayOrder = 1, IsActive = true },
            new() { MasterDataDefId = Guid.NewGuid(), EntityCode = "EMPLOYMENT_TYPE", EntityName = "Employment Type", GroupName = "Employee Info", DisplayOrder = 2, IsActive = true },
            new() { MasterDataDefId = Guid.NewGuid(), EntityCode = "PROBATION_STATUS", EntityName = "Probation Status", GroupName = "Employee Info", DisplayOrder = 3, IsActive = true },
            new() { MasterDataDefId = Guid.NewGuid(), EntityCode = "MARITAL_STATUS", EntityName = "Marital Status", GroupName = "Employee Info", DisplayOrder = 4, IsActive = true },
            new() { MasterDataDefId = Guid.NewGuid(), EntityCode = "JOB_TITLE", EntityName = "Job Title / Role", GroupName = "Employee Info", DisplayOrder = 5, IsActive = true },
            new() { MasterDataDefId = Guid.NewGuid(), EntityCode = "DEPARTMENT", EntityName = "Department", GroupName = "Employee Info", DisplayOrder = 6, IsActive = true },
            new() { MasterDataDefId = Guid.NewGuid(), EntityCode = "NATIONALITY", EntityName = "Nationality / Country", GroupName = "Employee Info", DisplayOrder = 7, IsActive = true },
            new() { MasterDataDefId = Guid.NewGuid(), EntityCode = "OFFICE_LOCATION", EntityName = "Office Location", GroupName = "Employee Info", DisplayOrder = 8, IsActive = true },
            new() { MasterDataDefId = Guid.NewGuid(), EntityCode = "RELATIONSHIP", EntityName = "Relationship", GroupName = "Employee Info", DisplayOrder = 9, IsActive = true },
            new() { MasterDataDefId = Guid.NewGuid(), EntityCode = "PHONE_CODE", EntityName = "Phone Code", GroupName = "Configurations", DisplayOrder = 10, IsActive = true },
            new() { MasterDataDefId = Guid.NewGuid(), EntityCode = "TAX_TYPE", EntityName = "Tax Type", GroupName = "Configurations", DisplayOrder = 11, IsActive = true },
            new() { MasterDataDefId = Guid.NewGuid(), EntityCode = "MS_LICENSE", EntityName = "Microsoft Access License", GroupName = "Configurations", DisplayOrder = 12, IsActive = true },
            new() { MasterDataDefId = Guid.NewGuid(), EntityCode = "LAPTOP_TYPE", EntityName = "Laptop Type", GroupName = "Configurations", DisplayOrder = 13, IsActive = true }
        };

        BuildSidebarGroups();

        if (_entityTabs.Any())
        {
            var first = _entityTabs.First();
            _selectedEntityCode = first.EntityCode;
            _selectedMasterDataDefId = first.MasterDataDefId;
        }

        _masterDataItems = new List<TenantMasterDataItemDto>
        {
            new() { Id = 1, FieldValues = new Dictionary<string, object?> { ["CODE"] = "WG01", ["VALUE"] = "Male", ["IS_ACTIVE"] = true } },
            new() { Id = 2, FieldValues = new Dictionary<string, object?> { ["CODE"] = "WG02", ["VALUE"] = "Female", ["IS_ACTIVE"] = true } },
            new() { Id = 3, FieldValues = new Dictionary<string, object?> { ["CODE"] = "WG03", ["VALUE"] = "Non-binary", ["IS_ACTIVE"] = false } },
            new() { Id = 4, FieldValues = new Dictionary<string, object?> { ["CODE"] = "WG04", ["VALUE"] = "Others", ["IS_ACTIVE"] = false } },
            new() { Id = 5, FieldValues = new Dictionary<string, object?> { ["CODE"] = "WG05", ["VALUE"] = "Prefer not to say", ["IS_ACTIVE"] = true } }
        };
    }

    private async Task LoadDataItemsAsync()
    {
        if (_selectedProductId == Guid.Empty || string.IsNullOrEmpty(_selectedEntityCode)) return;

        _isLoadingData = true;
        _currentPage = 1;
        StateHasChanged();

        try
        {
            _masterDataItems = await TenantMasterDataService.GetTenantDataItemsAsync(_selectedProductId, _selectedEntityCode);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading items: {ex.Message}");
            _masterDataItems = new();
        }
        finally
        {
            _isLoadingData = false;
            StateHasChanged();
        }
    }

    private async Task OnProductChanged(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var productId))
        {
            _selectedProductId = productId;
            await LoadProductSchemaAsync();
        }
    }

    private void OnScopeChanged(ChangeEventArgs e)
    {
        _selectedScope = e.Value?.ToString() ?? "product";
        StateHasChanged();
    }

    private void SelectScope(string scope)
    {
        _selectedScope = scope;
        StateHasChanged();
    }

    private void ToggleSidebarGroup(SidebarGroup group)
    {
        group.IsExpanded = !group.IsExpanded;
    }

    private async Task SelectSidebarEntity(MasterDataDefinitionWithFieldsDto entity)
    {
        _selectedEntityCode = entity.EntityCode;
        _selectedMasterDataDefId = entity.MasterDataDefId;
        _currentFields = entity.Fields;
        _searchQuery = "";
        await LoadDataItemsAsync();
    }

    private async Task RefreshData()
    {
        await LoadDataItemsAsync();
    }

    private string GetSelectedEntityName()
    {
        var tab = _entityTabs.FirstOrDefault(t => t.EntityCode == _selectedEntityCode);
        return tab?.EntityName ?? "Master Data";
    }

    private string GetSelectedProductName()
    {
        var product = _subscribedProducts.FirstOrDefault(p => p.ProductId == _selectedProductId);
        return product?.ProductName ?? "Product";
    }

    private string GetItemCode(TenantMasterDataItemDto item, int rowIndex)
    {
        if (item.FieldValues != null && item.FieldValues.TryGetValue("CODE", out var code) && code != null)
            return code.ToString() ?? $"#{rowIndex}";
        return $"#{rowIndex}";
    }

    private bool IsItemActive(TenantMasterDataItemDto item)
    {
        if (item.FieldValues != null && item.FieldValues.TryGetValue("IS_ACTIVE", out var val))
        {
            if (val is bool b) return b;
            if (val is System.Text.Json.JsonElement je && je.ValueKind == System.Text.Json.JsonValueKind.True) return true;
            if (bool.TryParse(val?.ToString(), out var parsed)) return parsed;
        }
        return true;
    }

    private void ToggleItemStatus(TenantMasterDataItemDto item, ChangeEventArgs e)
    {
        if (item.FieldValues != null)
        {
            item.FieldValues["IS_ACTIVE"] = bool.TryParse(e.Value?.ToString(), out var v) && v;
            StateHasChanged();
        }
    }

    private List<TenantMasterDataItemDto> GetPagedItems()
    {
        return FilteredItems
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize)
            .ToList();
    }

    private void GoToPage(int page)
    {
        _currentPage = page;
    }

    private void PreviousPage()
    {
        if (_currentPage > 1) _currentPage--;
    }

    private void NextPage()
    {
        if (_currentPage < TotalPages) _currentPage++;
    }

    // Modal operations
    private void OpenAddModal()
    {
        _isEditMode = false;
        _editItem = new EditItemModel { FieldValues = InitializeFieldValues() };
        _showModal = true;
    }

    private void OpenEditModal(TenantMasterDataItemDto item)
    {
        _isEditMode = true;
        _editItem = new EditItemModel
        {
            Id = item.Id,
            FieldValues = item.FieldValues ?? new Dictionary<string, object?>()
        };
        _showModal = true;
    }

    private Dictionary<string, object?> InitializeFieldValues()
    {
        var fieldValues = new Dictionary<string, object?>();
        foreach (var field in _currentFields.Where(f => f.ShowInForm))
        {
            if (!string.IsNullOrEmpty(field.DefaultValue))
                fieldValues[field.FieldCode] = ConvertDefaultValue(field.DefaultValue, field.DataType);
            else
                fieldValues[field.FieldCode] = GetDefaultForType(field.DataType);
        }
        return fieldValues;
    }

    private object? ConvertDefaultValue(string defaultValue, string dataType)
    {
        try
        {
            return dataType.ToLower() switch
            {
                "int" or "integer" or "number" => int.TryParse(defaultValue, out var intVal) ? intVal : null,
                "decimal" or "money" or "currency" => decimal.TryParse(defaultValue, out var decVal) ? decVal : null,
                "bool" or "boolean" => bool.TryParse(defaultValue, out var boolVal) && boolVal,
                "date" or "datetime" => DateTime.TryParse(defaultValue, out var dateVal) ? dateVal : null,
                _ => defaultValue
            };
        }
        catch { return null; }
    }

    private object? GetDefaultForType(string dataType)
    {
        return dataType.ToLower() switch
        {
            "int" or "integer" or "number" => null,
            "decimal" or "money" or "currency" => null,
            "bool" or "boolean" => false,
            "date" or "datetime" => null,
            _ => ""
        };
    }

    private void CloseModal()
    {
        _showModal = false;
        _editItem = new EditItemModel();
    }

    private async Task SaveItem()
    {
        if (_form == null) return;
        await _form.Validate();
        if (!_formIsValid) return;

        _isSaving = true;
        StateHasChanged();

        try
        {
            if (_isEditMode)
            {
                var updateDto = new UpdateTenantMasterDataItemDto
                {
                    ItemId = _editItem.Id,
                    FieldValues = _editItem.FieldValues
                };

                var result = await TenantMasterDataService.UpdateItemAsync(_selectedProductId, _selectedEntityCode, _editItem.Id, updateDto);
                if (result != null)
                {
                    Snackbar.Add("Item updated successfully", Severity.Success);
                    await LoadDataItemsAsync();
                    CloseModal();
                }
                else
                {
                    Snackbar.Add("Failed to update item", Severity.Error);
                }
            }
            else
            {
                var addDto = new AddTenantMasterDataItemDto
                {
                    MasterDataDefId = _selectedMasterDataDefId,
                    EntityCode = _selectedEntityCode,
                    FieldValues = _editItem.FieldValues
                };

                var result = await TenantMasterDataService.AddItemAsync(_selectedProductId, addDto);
                if (result != null)
                {
                    Snackbar.Add("Item added successfully", Severity.Success);
                    await LoadDataItemsAsync();
                    CloseModal();
                }
                else
                {
                    Snackbar.Add("Failed to add item", Severity.Error);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private async Task HandleDelete(TenantMasterDataItemDto item)
    {
        var isMandatory = item.FieldValues.TryGetValue("IS_MANDATORY", out var mandatory) &&
                          (mandatory is true || mandatory?.ToString()?.ToLower() == "true");
        if (isMandatory)
        {
            Snackbar.Add("Cannot delete a mandatory item", Severity.Warning);
            return;
        }

        var itemName = item.FieldValues.TryGetValue("NAME", out var name) ? name?.ToString() :
                       item.FieldValues.TryGetValue("VALUE", out var val) ? val?.ToString() : $"Item #{item.Id}";

        _deleteItemName = itemName ?? $"Item #{item.Id}";
        _itemToDelete = item;
        _showDeleteConfirm = true;
    }

    private async Task ConfirmDelete()
    {
        if (_itemToDelete == null) return;

        try
        {
            var result = await TenantMasterDataService.DeleteItemAsync(_selectedProductId, _selectedEntityCode, _itemToDelete.Id);
            if (result)
            {
                Snackbar.Add("Item deleted successfully", Severity.Success);
                await LoadDataItemsAsync();
            }
            else
            {
                Snackbar.Add("Failed to delete item", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _showDeleteConfirm = false;
            _itemToDelete = null;
        }
    }

    private void CancelDelete()
    {
        _showDeleteConfirm = false;
        _itemToDelete = null;
    }

    private void HandleImport()
    {
        Snackbar.Add("Import functionality coming soon", Severity.Info);
    }

    // View Models
    public class SubscribedProductViewModel
    {
        public Guid ProductId { get; set; }
        public string ProductCode { get; set; } = "";
        public string ProductName { get; set; } = "";
    }

    public class EditItemModel
    {
        public int Id { get; set; }
        public Dictionary<string, object?> FieldValues { get; set; } = new();
    }

    public class SidebarGroup
    {
        public string GroupName { get; set; } = "";
        public bool IsExpanded { get; set; } = true;
        public List<MasterDataDefinitionWithFieldsDto> Entities { get; set; } = new();
    }

    // Field value helpers
    private T? GetFieldValue<T>(string fieldCode)
    {
        if (_editItem.FieldValues.TryGetValue(fieldCode, out var value) && value != null)
        {
            try
            {
                if (value is T typedValue) return typedValue;
                if (value is System.Text.Json.JsonElement jsonElement)
                {
                    var json = jsonElement.GetRawText();
                    return System.Text.Json.JsonSerializer.Deserialize<T>(json);
                }
                var targetType = Nullable.GetUnderlyingType(typeof(T)) ?? typeof(T);
                return (T)Convert.ChangeType(value, targetType);
            }
            catch { return default; }
        }
        return default;
    }

    private void SetFieldValue(string fieldCode, object? value)
    {
        _editItem.FieldValues[fieldCode] = value;
    }

    private DateTime? GetFieldDateValue(string fieldCode)
    {
        var value = GetFieldValue<object>(fieldCode);
        if (value == null) return null;
        if (value is DateTime dt) return dt;
        if (value is System.Text.Json.JsonElement je && je.TryGetDateTime(out var jdt)) return jdt;
        if (DateTime.TryParse(value.ToString(), out var parsed)) return parsed;
        return null;
    }

    private string GetFieldDisplayValue(Dictionary<string, object?>? fieldValues, MasterDataFieldDto field)
    {
        if (fieldValues == null || !fieldValues.TryGetValue(field.FieldCode, out var value) || value == null)
            return "-";

        try
        {
            return field.DataType.ToLower() switch
            {
                "bool" or "boolean" => value is true || value.ToString()?.ToLower() == "true" ? "Yes" : "No",
                "date" => value is DateTime dt ? dt.ToString("yyyy-MM-dd") :
                          value is System.Text.Json.JsonElement je && je.TryGetDateTime(out var jdt) ? jdt.ToString("yyyy-MM-dd") :
                          DateTime.TryParse(value.ToString(), out var pdt) ? pdt.ToString("yyyy-MM-dd") : value.ToString() ?? "-",
                "datetime" => value is DateTime dtm ? dtm.ToString("yyyy-MM-dd HH:mm") :
                              value is System.Text.Json.JsonElement jem && jem.TryGetDateTime(out var jdtm) ? jdtm.ToString("yyyy-MM-dd HH:mm") :
                              DateTime.TryParse(value.ToString(), out var pdtm) ? pdtm.ToString("yyyy-MM-dd HH:mm") : value.ToString() ?? "-",
                "decimal" or "money" or "currency" or "number" => value is decimal dec ? dec.ToString("N2") :
                                                                   decimal.TryParse(value.ToString(), out var pdec) ? pdec.ToString("N2") : value.ToString() ?? "-",
                "int" or "integer" => value is int i ? i.ToString() : value.ToString() ?? "-",
                _ => value.ToString() ?? "-"
            };
        }
        catch { return value?.ToString() ?? "-"; }
    }
}
