@model IEnumerable<EmailLog>
@{ ViewData["Title"] = "Email Logs"; }
<div class="dashboard-layout"><div class="container">
<h1 class="mb-4"><a asp-action="Index" class="text-muted-lnk">Admin</a> / Email Logs</h1>
<div class="glass-card table-responsive">
<table class="table table-dark admin-table mb-0">
<thead><tr><th>To</th><th>Subject</th><th>Success</th><th>Sent</th></tr></thead>
<tbody>
@foreach (var e in Model) {
<tr><td>@e.ToEmail</td><td>@e.Subject</td><td>@(e.Success ? "✓" : "✗")</td><td>@e.SentAt</td></tr>
}
</tbody></table></div></div></div>
