@model IEnumerable<ApplicationUser>
@{ ViewData["Title"] = "Users"; }
<div class="dashboard-layout"><div class="container">
<h1 class="mb-4"><a asp-action="Index" class="text-muted-lnk">Admin</a> / Users</h1>
<div class="glass-card table-responsive">
<table class="table table-dark admin-table mb-0">
<thead><tr><th>Email</th><th>Name</th><th>Onboarded</th><th>Joined</th></tr></thead>
<tbody>
@foreach (var u in Model) {
<tr><td>@u.Email</td><td>@u.DisplayName</td><td>@(u.OnboardingCompleted ? "Yes" : "No")</td><td>@u.CreatedAt.ToString("yyyy-MM-dd")</td></tr>
}
</tbody></table></div></div></div>
