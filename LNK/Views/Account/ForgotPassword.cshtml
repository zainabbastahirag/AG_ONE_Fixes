@{ ViewData["Title"] = "Forgot password"; }
<div class="auth-page">
    <div class="auth-card glass-card text-center">
        <h2>Reset password</h2>
        <p class="text-muted-lnk">Email verification and password reset can be configured with SMTP in appsettings. Contact your administrator or check the README.</p>
        <a asp-action="Login" class="btn btn-lnk-ghost mt-3">Back to sign in</a>
    </div>
</div>
