@model WorkItem
@{
    ViewData["Title"] = "Delete Work Item";
}
<div class="page-head"><div><h1 class="page-title">Delete work item</h1><div class="page-sub">This action cannot be undone</div></div></div>
<div class="card-tp" style="max-width:560px"><div class="card-body">
    <p>Delete <strong>@Model.Title</strong>?</p>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</button>
        <a asp-action="Board" class="btn btn-soft">Cancel</a>
    </form>
</div></div>
