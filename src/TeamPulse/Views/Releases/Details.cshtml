@model Release
@{
    ViewData["Title"] = Model.Name;
    var b = UiHelpers.Badge(Model.Status);
}
<div class="page-head">
    <div><h1 class="page-title">@Model.Name <span class="text-muted-tp">@Model.Version</span></h1><div class="page-sub">@(Model.Team?.Name ?? "No team")</div></div>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin") || User.IsInRole("TechLead")) { <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-soft"><i class="bi bi-pencil"></i> Edit</a> }
        <a asp-action="Index" class="btn btn-soft"><i class="bi bi-arrow-left"></i></a>
    </div>
</div>
<div class="card-tp" style="max-width:780px"><div class="card-body">
    <div class="d-flex gap-2 mb-3"><span class="badge-tp @b.css">@b.label</span></div>
    <div class="d-flex align-items-center gap-2 mb-3"><div class="prog flex-grow-1"><span style="width:@(Model.ProgressPercent)%"></span></div><span class="small">@Model.ProgressPercent%</span></div>
    <div class="row mb-3">
        <div class="col-md-4"><div class="text-muted-tp small">Target Date</div><div class="fw-semibold">@(Model.TargetDate?.ToString("dd MMM yyyy") ?? "—")</div></div>
        <div class="col-md-4"><div class="text-muted-tp small">Released Date</div><div class="fw-semibold">@(Model.ReleasedDate?.ToString("dd MMM yyyy") ?? "—")</div></div>
        <div class="col-md-4"><div class="text-muted-tp small">Created</div><div class="fw-semibold">@Model.CreatedAt.ToString("dd MMM yyyy")</div></div>
    </div>
    <div class="text-muted-tp small">Notes</div>
    <p>@(string.IsNullOrEmpty(Model.Notes) ? "—" : Model.Notes)</p>
</div></div>
