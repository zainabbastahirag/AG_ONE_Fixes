@model Team
@{
    ViewData["Title"] = "Delete Team";
}
<div class="page-head"><div><h1 class="page-title">Delete team</h1><div class="page-sub">This action cannot be undone</div></div></div>
<div class="card-tp" style="max-width:560px"><div class="card-body">
    <p>Are you sure you want to delete <strong>@Model.Name</strong>? Its @Model.Members.Count member(s) will be unassigned.</p>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Delete</button>
        <a asp-action="Index" class="btn btn-soft">Cancel</a>
    </form>
</div></div>
