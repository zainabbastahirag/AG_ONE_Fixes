@model Sprint
<div class="row g-3">
    <div class="col-md-8">
        <label class="form-label">Sprint Name</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label class="form-label">Number</label>
        <input asp-for="Number" type="number" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Quarter</label>
        <input asp-for="Quarter" type="number" min="1" max="4" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Year</label>
        <input asp-for="Year" type="number" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Start</label>
        <input asp-for="StartDate" type="date" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">End</label>
        <input asp-for="EndDate" type="date" class="form-control" />
    </div>
    <div class="col-12">
        <label class="form-label">Goal</label>
        <textarea asp-for="Goal" class="form-control" rows="2"></textarea>
    </div>
    <div class="col-12">
        <div class="form-check">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">Set as active sprint (deactivates others)</label>
        </div>
    </div>
</div>
