@model List<Sprint>
@{
    ViewData["Title"] = "Sprints";
    var canManage = User.IsInRole("Admin") || User.IsInRole("TechLead");
}
<div class="page-head">
    <div><h1 class="page-title">Sprints</h1><div class="page-sub">@Model.Count sprints</div></div>
    @if (canManage) { <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Sprint</a> }
</div>
<div class="row g-4">
@foreach (var s in Model)
{
    var done = s.WorkItems.Count(w => w.Status == WorkItemStatus.Done);
    var total = s.WorkItems.Count;
    var pct = total > 0 ? (int)Math.Round(done * 100.0 / total) : 0;
    <div class="col-md-6 col-xl-4">
        <div class="card-tp h-100"><div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <h5 class="mb-0">@s.Name</h5>
                @if (s.IsActive) { <span class="badge-tp b-green">Active</span> } else { <span class="badge-tp b-gray">Q@s.Quarter @s.Year</span> }
            </div>
            <div class="text-muted-tp mb-3" style="font-size:13px;min-height:36px">@(s.Goal ?? "No goal set")</div>
            <div class="text-muted-tp small mb-1">@s.StartDate.ToString("dd MMM") – @s.EndDate.ToString("dd MMM yyyy")</div>
            <div class="d-flex align-items-center gap-2 mb-3">
                <div class="prog flex-grow-1"><span style="width:@(pct)%"></span></div>
                <span class="small">@done/@total</span>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-soft flex-grow-1">View</a>
                @if (canManage) { <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-soft"><i class="bi bi-pencil"></i></a> }
            </div>
        </div></div>
    </div>
}
</div>
