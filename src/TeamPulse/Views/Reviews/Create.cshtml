@model PerformanceReview
@{
    ViewData["Title"] = "New Review";
}
<div class="page-head">
    <div><h1 class="page-title">New Performance Review</h1><div class="page-sub">Score across five dimensions and add qualitative feedback</div></div>
    <a asp-action="Index" class="btn btn-soft"><i class="bi bi-arrow-left"></i> Back</a>
</div>
<div class="card-tp" style="max-width:880px"><div class="card-body">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <partial name="_Form" model="Model" />
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Submit Review</button>
            <a asp-action="Index" class="btn btn-soft">Cancel</a>
        </div>
    </form>
</div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
