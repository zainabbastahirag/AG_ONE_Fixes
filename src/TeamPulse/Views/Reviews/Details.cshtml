@model PerformanceReview
@{
    ViewData["Title"] = "Review";
    var ratings = new (string Label, int Value)[] {
        ("Delivery", Model.RatingDelivery),
        ("Quality", Model.RatingQuality),
        ("Collaboration", Model.RatingCollaboration),
        ("Ownership", Model.RatingOwnership),
        ("Innovation", Model.RatingInnovation)
    };
}
<div class="page-head">
    <div>
        <h1 class="page-title">@(Model.Member?.FullName) — Review</h1>
        <div class="page-sub">@(Model.PeriodType == ReviewPeriodType.Sprint ? (Model.Sprint?.Name ?? "Sprint") : $"Q{Model.Quarter} {Model.Year}") · by @(Model.Reviewer?.FullName ?? "—")</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-soft"><i class="bi bi-pencil"></i> Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-soft text-danger"><i class="bi bi-trash"></i></a>
        <a asp-action="Index" class="btn btn-soft"><i class="bi bi-arrow-left"></i></a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card-tp"><div class="card-body text-center">
            <div class="text-muted-tp small">Overall Rating</div>
            <div style="font-size:46px;font-weight:800;line-height:1">@Model.OverallRating.ToString("0.0")</div>
            <div class="stars" style="font-size:24px">@UiHelpers.Stars(Model.OverallRating)</div>
        </div></div>
        <div class="card-tp mt-4"><div class="card-body">
            @foreach (var r in ratings)
            {
                <div class="mb-3">
                    <div class="d-flex justify-content-between"><span style="font-size:14px">@r.Label</span><span class="fw-semibold">@r.Value/5</span></div>
                    <div class="prog"><span style="width:@(r.Value * 20)%"></span></div>
                </div>
            }
        </div></div>
    </div>
    <div class="col-lg-7">
        <div class="card-tp"><div class="card-body">
            <h6 class="text-muted-tp" style="text-transform:uppercase;font-size:12px">Strengths</h6>
            <p>@(string.IsNullOrEmpty(Model.Strengths) ? "—" : Model.Strengths)</p>
            <h6 class="text-muted-tp mt-3" style="text-transform:uppercase;font-size:12px">Areas to Improve</h6>
            <p>@(string.IsNullOrEmpty(Model.Improvements) ? "—" : Model.Improvements)</p>
            <h6 class="text-muted-tp mt-3" style="text-transform:uppercase;font-size:12px">Comments</h6>
            <p class="mb-0">@(string.IsNullOrEmpty(Model.Comments) ? "—" : Model.Comments)</p>
        </div></div>
    </div>
</div>
