@using Microsoft.AspNetCore.Identity
@using TeamPulse.Models.Domain
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    var currentUser = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;
    string Active(string controller) =>
        string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), controller, StringComparison.OrdinalIgnoreCase)
            ? "active" : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · TeamPulse</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@if (SignInManager.IsSignedIn(User))
{
    <div class="app-shell">
        <aside class="sidebar">
            <div class="brand">
                <span class="brand-mark"><i class="bi bi-activity"></i></span>
                <div>
                    <div class="brand-name">TeamPulse</div>
                    <div class="brand-sub">Command Center</div>
                </div>
            </div>
            <nav class="nav-menu">
                <a class="nav-link @Active("Dashboard")" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2"></i> Dashboard</a>
                <a class="nav-link @Active("Teams")" asp-controller="Teams" asp-action="Index"><i class="bi bi-diagram-3"></i> Teams</a>
                <a class="nav-link @Active("Members")" asp-controller="Members" asp-action="Index"><i class="bi bi-people"></i> Resources</a>
                <a class="nav-link @Active("WorkItems")" asp-controller="WorkItems" asp-action="Board"><i class="bi bi-kanban"></i> Work Tracker</a>
                <a class="nav-link @Active("Sprints")" asp-controller="Sprints" asp-action="Index"><i class="bi bi-flag"></i> Sprints</a>
                <a class="nav-link @Active("Releases")" asp-controller="Releases" asp-action="Index"><i class="bi bi-rocket-takeoff"></i> Releases</a>
                <a class="nav-link @Active("Reviews")" asp-controller="Reviews" asp-action="Index"><i class="bi bi-star"></i> Performance</a>
                @if (User.IsInRole("Admin"))
                {
                    <div class="nav-section">Admin</div>
                    <a class="nav-link @Active("Invitations")" asp-controller="Invitations" asp-action="Index"><i class="bi bi-envelope-paper"></i> Invitations</a>
                    <a class="nav-link @Active("Reviews")" asp-controller="Reviews" asp-action="Assignments"><i class="bi bi-person-check"></i> Reviewer Setup</a>
                }
            </nav>
            <div class="sidebar-footer">
                <div class="user-chip">
                    <span class="avatar" style="background:@(currentUser?.AvatarColor ?? "#4f46e5")">@((currentUser?.FullName ?? "U").Trim().Substring(0,1).ToUpper())</span>
                    <div class="user-meta">
                        <div class="user-name">@(currentUser?.FullName ?? User.Identity?.Name)</div>
                        <div class="user-role">@(currentUser?.JobTitle ?? "Member")</div>
                    </div>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn btn-sm btn-logout w-100"><i class="bi bi-box-arrow-right"></i> Sign out</button>
                </form>
            </div>
        </aside>
        <main class="main-area">
            <div class="content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </main>
    </div>
}
else
{
    @RenderBody()
}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
