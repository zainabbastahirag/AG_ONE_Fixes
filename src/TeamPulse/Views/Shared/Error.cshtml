@model ErrorViewModel
@{
    ViewData["Title"] = Model.IsNotFound ? "Page not found" : "Error";
}

@if (Model.IsNotFound)
{
    <h1 class="text-danger">404 — Page not found.</h1>
    <h2 class="text-danger">We couldn't find the page you were looking for.</h2>
    <p>
        The address may be mistyped, or the page may have moved.
        <a asp-controller="Dashboard" asp-action="Index">Go back to the dashboard</a>.
    </p>
}
else
{
    <h1 class="text-danger">@(Model.StatusCode.HasValue ? $"{Model.StatusCode} — Error." : "Error.")</h1>
    <h2 class="text-danger">An error occurred while processing your request.</h2>
}

@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}
