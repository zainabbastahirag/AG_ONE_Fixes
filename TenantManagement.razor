@code {
    // ═══ Tab State ═══
    private string _activeTab = "company";
    private string _companySubTab = "profile";
    private string _auditSubTab = "logs";

    // ═══ Loading State ═══
    private bool _isLoading;
    private bool _isSaving;

    // ═══ Company Profile ═══
    private CompanyProfileDto _companyProfile = new();

    // ═══ SSO Config ═══
    private SsoConfigDto _ssoConfig = new();

    // ═══ API Keys ═══
    private List<ApiKeyDto> _apiKeys = new();
    private bool _showCreateKeyDialog;
    private bool _showFullKeyDialog;
    private string _newKeyName = "";
    private string _createdFullKey = "";

    // ═══ Audit Logs ═══
    private AuditResponseDto _auditResponse = new();
    private string _auditSearch = "";
    private int _auditPage = 1;
    private int _pageSize = 10;

    // ═══ Login History ═══
    private List<LoginHistoryDto> _loginHistory = new();
    private int _loginPage = 1;
    private int _loginTotalCount;

    // ═══ Computed ═══
    private int AuditTotalPages => Math.Max(1, (int)Math.Ceiling((double)_auditResponse.TotalCount / _pageSize));
    private int LoginTotalPages => Math.Max(1, (int)Math.Ceiling((double)_loginTotalCount / _pageSize));

    // ═══ Tab Loaded Flags ═══
    private bool _companyLoaded;
    private bool _ssoLoaded;
    private bool _apiLoaded;
    private bool _auditLoaded;
    private bool _loginLoaded;

    // ═══ Lifecycle ═══
    protected override async Task OnInitializedAsync()
    {
        await LoadCompanyProfile();
    }

    // ═══ Tab Switching ═══
    private async Task SwitchTab(string tab)
    {
        _activeTab = tab;
        switch (tab)
        {
            case "company":
                if (!_companyLoaded)
                    await LoadCompanyProfile();
                break;
            case "sso":
                if (!_ssoLoaded)
                    await LoadSsoConfig();
                break;
            case "api":
                if (!_apiLoaded)
                    await LoadApiKeys();
                break;
            case "audit":
                if (!_auditLoaded)
                    await LoadAuditLogs();
                break;
        }
    }

    private async Task SwitchAuditSubTab(string subTab)
    {
        _auditSubTab = subTab;
        if (subTab == "logs" && !_auditLoaded)
            await LoadAuditLogs();
        else if (subTab == "logins" && !_loginLoaded)
