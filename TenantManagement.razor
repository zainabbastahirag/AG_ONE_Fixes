    private void OpenCreateKeyDialog()
    {
        _newKeyName = "";
        _showCreateKeyDialog = true;
    }

    private void CloseCreateKeyDialog()
    {
        _showCreateKeyDialog = false;
        _newKeyName = "";
    }

    private async Task CreateApiKey()
    {
        if (string.IsNullOrWhiteSpace(_newKeyName)) return;

        _isSaving = true;
        StateHasChanged();
        try
        {
            var response = await Http.PostAsJsonAsync("api/tenant-management/api-keys", new { Name = _newKeyName });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<CreateApiKeyResponseDto>();
                _showCreateKeyDialog = false;
                if (result != null)
                {
                    _createdFullKey = result.FullKey;
                    _showFullKeyDialog = true;
                    Snackbar.Add($"API key '{result.Name}' created successfully", Severity.Success);
                }
                await LoadApiKeys();
            }
            else
            {
                Snackbar.Add($"Failed to create API key: {response.StatusCode}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating API key: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

    private void CloseFullKeyDialog()
    {
        _showFullKeyDialog = false;
        _createdFullKey = "";
    }

    private async Task RevokeApiKey(Guid id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/tenant-management/api-keys/{id}");
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("API key revoked successfully", Severity.Success);
                await LoadApiKeys();
            }
            else
            {
                Snackbar.Add($"Failed to revoke API key: {response.StatusCode}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error revoking API key: {ex.Message}", Severity.Error);
        }
    }

