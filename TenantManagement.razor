@page "/admin/apps"
@layout AdminLayout
@attribute [Authorize]
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>Tenant Management - AGOne</PageTitle>

<div class="tm-page">
    <div class="tm-header">
        <div>
            <h1 class="tm-title">Tenant Management</h1>
            <p class="tm-subtitle">Manage your company settings, SSO configuration, API keys and audit logs</p>
        </div>
    </div>

    <!-- ═══ Main Tabs ═══ -->
    <div class="tm-tabs">
        <button class="tm-tab @(_activeTab == "company" ? "active" : "")" @onclick='() => SwitchTab("company")'>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>
            Company Settings
        </button>
        <button class="tm-tab @(_activeTab == "sso" ? "active" : "")" @onclick='() => SwitchTab("sso")'>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            SSO Configuration
        </button>
        <button class="tm-tab @(_activeTab == "api" ? "active" : "")" @onclick='() => SwitchTab("api")'>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
            API Management
        </button>
        <button class="tm-tab @(_activeTab == "audit" ? "active" : "")" @onclick='() => SwitchTab("audit")'>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            Audit &amp; Visibility
        </button>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- COMPANY SETTINGS TAB                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    @if (_activeTab == "company")
    {
        <div class="tm-subtabs">
            <button class="tm-subtab @(_companySubTab == "profile" ? "active" : "")" @onclick='() => _companySubTab = "profile"'>Company Profile</button>
            <button class="tm-subtab @(_companySubTab == "entities" ? "active" : "")" @onclick='() => _companySubTab = "entities"'>Entities &amp; Tax</button>
        </div>

        @if (_companySubTab == "profile")
        {
            @if (_isLoading)
            {
                <div class="tm-loading">
                    <div class="tm-spinner-lg"></div>
                    <p>Loading company profile...</p>
                </div>
            }
            else
            {
                <div class="tm-card">
                    <h2 class="tm-card-title">Company Profile</h2>
                    <p class="tm-card-desc">Update your company information that will be visible across the platform.</p>

                    <div class="tm-form-grid">
                        <div class="tm-field">
                            <label class="tm-label">Company Name</label>
                            <input type="text" class="tm-input" @bind="_companyProfile.Name" placeholder="Enter company name" />
                        </div>
                        <div class="tm-field">
                            <label class="tm-label">Industry</label>
                            <input type="text" class="tm-input" @bind="_companyProfile.Industry" placeholder="e.g. Technology, Healthcare" />
                        </div>
                        <div class="tm-field">
                            <label class="tm-label">Company Size</label>
                            <input type="text" class="tm-input" @bind="_companyProfile.Size" placeholder="e.g. 50-200 employees" />
                        </div>
                        <div class="tm-field">
                            <label class="tm-label">Website</label>
                            <input type="text" class="tm-input" @bind="_companyProfile.Website" placeholder="https://example.com" />
                        </div>
                        <div class="tm-field">
                            <label class="tm-label">Email</label>
                            <input type="email" class="tm-input" @bind="_companyProfile.Email" placeholder="company@example.com" />
                        </div>
                        <div class="tm-field">
                            <label class="tm-label">Phone</label>
                            <input type="text" class="tm-input" @bind="_companyProfile.Phone" placeholder="+60 12-345 6789" />
                        </div>
                    </div>
                    <div class="tm-field tm-field-full">
                        <label class="tm-label">Description</label>
                        <textarea class="tm-textarea" rows="3" @bind="_companyProfile.Description" placeholder="Brief description of your company"></textarea>
                    </div>

                    <div class="tm-form-actions">
                        <button class="tm-btn-outline" @onclick="CancelCompanyProfile" disabled="@_isSaving">Cancel</button>
                        <button class="tm-btn-primary" @onclick="SaveCompanyProfile" disabled="@_isSaving">
                            @if (_isSaving)
                            {
                                <span class="tm-spinner"></span>
                            }
                            Save Changes
                        </button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="tm-card">
                <div class="tm-coming-soon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/>
                    </svg>
                    <h3>Entities &amp; Tax</h3>
                    <p>This section is coming soon. You will be able to manage legal entities and tax configurations here.</p>
                </div>
            </div>
        }
    }

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SSO CONFIGURATION TAB                                              -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    @if (_activeTab == "sso")
    {
        @if (_isLoading)
        {
            <div class="tm-loading">
                <div class="tm-spinner-lg"></div>
                <p>Loading SSO configuration...</p>
            </div>
        }
        else
        {
            <div class="tm-card">
                <div class="tm-sso-header">
                    <div>
                        <h2 class="tm-card-title">Single Sign-On (SSO)</h2>
                        <p class="tm-card-desc">Configure SSO to allow users to sign in with your identity provider.</p>
                    </div>
                    <label class="tm-toggle">
                        <input type="checkbox" @bind="_ssoConfig.IsEnabled" />
                        <span class="tm-toggle-slider"></span>
                        <span class="tm-toggle-label">@(_ssoConfig.IsEnabled ? "Enabled" : "Disabled")</span>
                    </label>
                </div>

                <div class="tm-form-grid">
                    <div class="tm-field">
                        <label class="tm-label">Instance URL</label>
                        <input type="text" class="tm-input" @bind="_ssoConfig.InstanceUrl" placeholder="https://login.microsoftonline.com" disabled="@(!_ssoConfig.IsEnabled)" />
                    </div>
                    <div class="tm-field">
                        <label class="tm-label">Tenant ID</label>
                        <input type="text" class="tm-input" @bind="_ssoConfig.TenantId" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" disabled="@(!_ssoConfig.IsEnabled)" />
                    </div>
                    <div class="tm-field">
                        <label class="tm-label">Client ID</label>
                        <input type="text" class="tm-input" @bind="_ssoConfig.ClientId" placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" disabled="@(!_ssoConfig.IsEnabled)" />
                    </div>
                    <div class="tm-field">
                        <label class="tm-label">Active Users</label>
                        <input type="number" class="tm-input" @bind="_ssoConfig.ActiveUsers" disabled="@true" />
                    </div>
                </div>

                <div class="tm-form-actions">
                    <button class="tm-btn-outline" @onclick="CancelSso" disabled="@_isSaving">Cancel</button>
                    <button class="tm-btn-primary" @onclick="SaveSso" disabled="@_isSaving">
                        @if (_isSaving)
                        {
                            <span class="tm-spinner"></span>
                        }
                        Save Changes
                    </button>
                </div>
            </div>
        }
    }

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- API MANAGEMENT TAB                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    @if (_activeTab == "api")
    {
        @if (_isLoading)
        {
            <div class="tm-loading">
                <div class="tm-spinner-lg"></div>
                <p>Loading API keys...</p>
            </div>
        }
        else
        {
            <div class="tm-card">
                <div class="tm-api-header">
                    <div>
                        <h2 class="tm-card-title">API Keys</h2>
                        <p class="tm-card-desc">Manage API keys for integrating with external systems.</p>
                    </div>
                    <button class="tm-btn-primary" @onclick="OpenCreateKeyDialog">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                        Create API Key
                    </button>
                </div>

                @if (!_apiKeys.Any())
                {
                    <div class="tm-empty">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
                        <p>No API keys found. Create one to get started.</p>
                    </div>
                }
                else
                {
                    <div class="tm-table-card">
                        <div class="tm-table-wrap">
                            <table class="tm-table">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Key</th>
                                        <th>Created</th>
                                        <th>Last Used</th>
                                        <th class="tm-th-action">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var key in _apiKeys)
                                    {
                                        <tr>
                                            <td class="tm-td-name">@key.Name</td>
                                            <td class="tm-td-key"><code>@key.KeyPrefix...@key.KeySuffix</code></td>
                                            <td class="tm-td-date">@key.CreatedAt.ToString("MMM dd, yyyy")</td>
                                            <td class="tm-td-date">@(key.LastUsedAt.HasValue ? key.LastUsedAt.Value.ToString("MMM dd, yyyy") : "Never")</td>
                                            <td class="tm-td-action">
                                                <button class="tm-btn-danger-sm" @onclick="() => RevokeApiKey(key.Id)" title="Revoke">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                                                    Revoke
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Create Key Dialog -->
        @if (_showCreateKeyDialog)
        {
            <div class="tm-modal-overlay" @onclick="CloseCreateKeyDialog">
                <div class="tm-modal" @onclick:stopPropagation="true">
                    <div class="tm-modal-header">
                        <h3>Create New API Key</h3>
                        <button class="tm-modal-close" @onclick="CloseCreateKeyDialog">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                        </button>
                    </div>
                    <div class="tm-modal-body">
                        <div class="tm-field">
                            <label class="tm-label">Key Name</label>
                            <input type="text" class="tm-input" @bind="_newKeyName" placeholder="e.g. Production Integration" />
                        </div>
                    </div>
                    <div class="tm-modal-footer">
                        <button class="tm-btn-outline" @onclick="CloseCreateKeyDialog">Cancel</button>
                        <button class="tm-btn-primary" @onclick="CreateApiKey" disabled="@(string.IsNullOrWhiteSpace(_newKeyName) || _isSaving)">
                            @if (_isSaving)
                            {
                                <span class="tm-spinner"></span>
                            }
                            Create Key
                        </button>
                    </div>
                </div>
            </div>
        }

        <!-- Show Full Key Dialog -->
        @if (_showFullKeyDialog)
        {
            <div class="tm-modal-overlay" @onclick="CloseFullKeyDialog">
                <div class="tm-modal" @onclick:stopPropagation="true">
                    <div class="tm-modal-header">
                        <h3>API Key Created</h3>
                        <button class="tm-modal-close" @onclick="CloseFullKeyDialog">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                        </button>
                    </div>
                    <div class="tm-modal-body">
                        <div class="tm-key-warning">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                            <span>Copy this key now. You won't be able to see it again.</span>
                        </div>
                        <div class="tm-key-display">
                            <code>@_createdFullKey</code>
                        </div>
                    </div>
                    <div class="tm-modal-footer">
                        <button class="tm-btn-primary" @onclick="CloseFullKeyDialog">Done</button>
                    </div>
                </div>
            </div>
        }
    }

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- AUDIT & VISIBILITY TAB                                             -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    @if (_activeTab == "audit")
    {
        <div class="tm-subtabs">
            <button class="tm-subtab @(_auditSubTab == "logs" ? "active" : "")" @onclick='() => SwitchAuditSubTab("logs")'>Audit Logs</button>
            <button class="tm-subtab @(_auditSubTab == "logins" ? "active" : "")" @onclick='() => SwitchAuditSubTab("logins")'>Login History</button>
        </div>

        @if (_auditSubTab == "logs")
        {
            @if (_isLoading)
            {
                <div class="tm-loading">
                    <div class="tm-spinner-lg"></div>
                    <p>Loading audit logs...</p>
                </div>
            }
            else
            {
                <!-- Stat Cards -->
                <div class="tm-stats-grid">
                    <div class="tm-stat-card">
                        <div class="tm-stat-icon tm-stat-blue">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                        </div>
                        <div class="tm-stat-info">
                            <span class="tm-stat-value">@_auditResponse.TotalEvents7d</span>
                            <span class="tm-stat-label">Total Events (7d)</span>
                        </div>
                    </div>
                    <div class="tm-stat-card">
                        <div class="tm-stat-icon tm-stat-green">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        </div>
                        <div class="tm-stat-info">
                            <span class="tm-stat-value">@_auditResponse.UserChanges</span>
                            <span class="tm-stat-label">User Changes</span>
                        </div>
                    </div>
                    <div class="tm-stat-card">
                        <div class="tm-stat-icon tm-stat-purple">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        </div>
                        <div class="tm-stat-info">
                            <span class="tm-stat-value">@_auditResponse.RoleChanges</span>
                            <span class="tm-stat-label">Role Changes</span>
                        </div>
                    </div>
                    <div class="tm-stat-card">
                        <div class="tm-stat-icon tm-stat-orange">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>
                        </div>
                        <div class="tm-stat-info">
                            <span class="tm-stat-value">@_auditResponse.ApiCalls</span>
                            <span class="tm-stat-label">API Calls</span>
                        </div>
                    </div>
                </div>

                <!-- Search -->
                <div class="tm-toolbar">
                    <div class="tm-search-wrap">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="tm-search-icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                        <input type="text" class="tm-search" placeholder="Search audit logs..." @bind="_auditSearch" @bind:event="oninput" @onkeyup="OnAuditSearchKeyUp" />
                    </div>
                    <button class="tm-icon-btn" title="Refresh" @onclick="LoadAuditLogs">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
                    </button>
                </div>

                <!-- Audit Table -->
                <div class="tm-table-card">
                    <div class="tm-table-wrap">
                        <table class="tm-table">
                            <thead>
                                <tr>
                                    <th>Timestamp</th>
                                    <th>User</th>
                                    <th>Type</th>
                                    <th>Action</th>
                                    <th>Details</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!_auditResponse.Items.Any())
                                {
                                    <tr><td colspan="5" class="tm-empty-row">No audit logs found</td></tr>
                                }
                                @foreach (var item in _auditResponse.Items)
                                {
                                    <tr>
                                        <td class="tm-td-date">@item.Timestamp.ToString("MMM dd, yyyy HH:mm")</td>
                                        <td class="tm-td-user">@item.User</td>
                                        <td><span class="tm-type-badge @GetAuditTypeCss(item.Type)">@item.Type</span></td>
                                        <td>@item.Action</td>
                                        <td class="tm-td-details">@item.Details</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="tm-table-footer">
                        <span class="tm-showing">Showing @((_auditPage - 1) * _pageSize + 1) to @(Math.Min(_auditPage * _pageSize, _auditResponse.TotalCount)) of @_auditResponse.TotalCount entries</span>
                        <div class="tm-pagination">
                            <button class="tm-page-btn" disabled="@(_auditPage <= 1)" @onclick="() => GoToAuditPage(_auditPage - 1)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
                            </button>
                            @foreach (var pg in GetVisiblePages(_auditPage, AuditTotalPages))
                            {
                                @if (pg == -1)
                                {
                                    <span class="tm-page-dots">...</span>
                                }
                                else
                                {
                                    var pageNum = pg;
                                    <button class="tm-page-btn @(pageNum == _auditPage ? "active" : "")" @onclick="() => GoToAuditPage(pageNum)">@pageNum</button>
                                }
                            }
                            <button class="tm-page-btn" disabled="@(_auditPage >= AuditTotalPages)" @onclick="() => GoToAuditPage(_auditPage + 1)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            @if (_isLoading)
            {
                <div class="tm-loading">
                    <div class="tm-spinner-lg"></div>
                    <p>Loading login history...</p>
                </div>
            }
            else
            {
                <div class="tm-table-card">
                    <div class="tm-table-wrap">
                        <table class="tm-table">
                            <thead>
                                <tr>
                                    <th>Timestamp</th>
                                    <th>User</th>
                                    <th>IP Address</th>
                                    <th>Browser</th>
                                    <th>OS</th>
                                    <th>Location</th>
                                    <th>Product</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!_loginHistory.Any())
                                {
                                    <tr><td colspan="8" class="tm-empty-row">No login history found</td></tr>
                                }
                                @foreach (var item in _loginHistory)
                                {
                                    <tr>
                                        <td class="tm-td-date">@item.Timestamp.ToString("MMM dd, yyyy HH:mm")</td>
                                        <td>
                                            <div class="tm-login-user">
                                                <span class="tm-login-user-name">@item.UserName</span>
                                                <span class="tm-login-user-email">@item.UserEmail</span>
                                            </div>
                                        </td>
                                        <td class="tm-td-mono">@item.IpAddress</td>
                                        <td>@item.Browser</td>
                                        <td>@item.OperatingSystem</td>
                                        <td>@item.Location</td>
                                        <td>@item.ProductName</td>
                                        <td>
                                            @if (item.IsSuccessful)
                                            {
                                                <span class="tm-status-success">Success</span>
                                            }
                                            else
                                            {
                                                <span class="tm-status-failed" title="@item.FailureReason">Failed</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="tm-table-footer">
                        <span class="tm-showing">Showing @((_loginPage - 1) * _pageSize + 1) to @(Math.Min(_loginPage * _pageSize, _loginTotalCount)) of @_loginTotalCount entries</span>
                        <div class="tm-pagination">
                            <button class="tm-page-btn" disabled="@(_loginPage <= 1)" @onclick="() => GoToLoginPage(_loginPage - 1)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
                            </button>
                            @foreach (var pg in GetVisiblePages(_loginPage, LoginTotalPages))
                            {
                                @if (pg == -1)
                                {
                                    <span class="tm-page-dots">...</span>
                                }
                                else
                                {
                                    var pageNum = pg;
                                    <button class="tm-page-btn @(pageNum == _loginPage ? "active" : "")" @onclick="() => GoToLoginPage(pageNum)">@pageNum</button>
                                }
                            }
                            <button class="tm-page-btn" disabled="@(_loginPage >= LoginTotalPages)" @onclick="() => GoToLoginPage(_loginPage + 1)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    }
</div>

