    // ═══════════════════════════════════════════════════════════════════
    // PAGINATION HELPER
    // ═══════════════════════════════════════════════════════════════════

    private List<int> GetVisiblePages(int currentPage, int totalPages)
    {
        const int maxVisible = 5;
        var pages = new List<int>();

        if (totalPages <= maxVisible)
        {
            for (int i = 1; i <= totalPages; i++) pages.Add(i);
            return pages;
        }

        int start = Math.Max(1, currentPage - 2);
        int end = Math.Min(totalPages, start + maxVisible - 1);
        if (end - start < maxVisible - 1) start = Math.Max(1, end - maxVisible + 1);

        if (start > 1) { pages.Add(1); if (start > 2) pages.Add(-1); }
        for (int i = start; i <= end; i++) pages.Add(i);
        if (end < totalPages) { if (end < totalPages - 1) pages.Add(-1); pages.Add(totalPages); }

        return pages;
    }

