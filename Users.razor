@code {
    private bool _isLoading = true;
    private List<UserDto> _users = new();
    private List<SubscribedProduct> _subscribedProducts = new();
    private List<Shared.DTOs.RoleDto> _allRoles = new();
    private string _searchTerm = "";
    private string _statusFilter = "all";
    private Guid? _selectedProductFilter;

    // Pagination
    private int _currentPage = 1;
    private int _pageSize = 10;

    // Roles dialog
    private bool _showRolesDialog;
    private UserDto? _selectedUser;
    private string _rolesTab = "roles";
    private List<UserRoleDto> _userRoles = new();
    private bool _loadingRoles;
    private bool _savingPriorities;

    // Remove role
    private bool _showRemoveRoleConfirm;
    private UserRoleDto? _roleToRemove;

    // Filtered + paginated
    private IEnumerable<UserDto> FilteredUsers
    {
        get
        {
            var q = _users.AsEnumerable();
            q = _statusFilter switch
            {
                "active" => q.Where(u => u.IsActive),
                "inactive" => q.Where(u => !u.IsActive && (u.LastLoginAt.HasValue || string.IsNullOrEmpty(u.Email))),
                "invited" => q.Where(u => !u.IsActive && !string.IsNullOrEmpty(u.Email) && !u.LastLoginAt.HasValue),
                _ => q
            };
            if (_selectedProductFilter.HasValue)
                q = q.Where(u => u.AssignedProductIds?.Contains(_selectedProductFilter.Value) == true);
            if (!string.IsNullOrWhiteSpace(_searchTerm))
                q = q.Where(u =>
                    (u.FirstName ?? "").Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    (u.LastName ?? "").Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    (u.Email ?? "").Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));
            return q.OrderBy(u => u.FirstName ?? "");
        }
    }

    private int TotalFilteredCount => FilteredUsers.Count();
    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)TotalFilteredCount / _pageSize));
    private IEnumerable<UserDto> PagedUsers => FilteredUsers.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try { var subs = await SubscriptionService.GetMySubscriptionsAsync(); _subscribedProducts = subs.Where(s => s.Status == "Active").Select(s => new SubscribedProduct { Id = s.ProductId, Name = s.ProductName ?? "Product" }).ToList(); } catch { }
        try { _allRoles = await InvitationApi.GetTenantRolesAsync(); } catch { }
        try { _users = await UserService.GetAllAsync(); } catch { }
        _isLoading = false;
    }

    private async Task RefreshUsers() { _isLoading = true; StateHasChanged(); try { _users = await UserService.GetAllAsync(); } catch { } _isLoading = false; _currentPage = 1; Snackbar.Add("Refreshed", Severity.Info); }
    private void ToggleAllSelection() { var val = !PagedUsers.All(u => u.IsSelected); foreach (var u in PagedUsers) u.IsSelected = val; }

    // Navigation
    private void GoToAssignAccess() => Nav.NavigateTo("/admin/users/assign-access");
    private void GoToAssignAccessForUser(UserDto user) { CloseRolesDialog(); Nav.NavigateTo($"/admin/users/assign-access?userId={user.Id}"); }
    private void OpenBulkInvite() => Snackbar.Add("Bulk invite coming soon", Severity.Info);

    // Display helpers
    private string GetUserId(UserDto u) => !string.IsNullOrEmpty(u.EmployeeId) ? u.EmployeeId : $"AG-{u.Id.ToString()[..4].ToUpper()}";
    private string GetEntity(UserDto? u) => u?.TenantName ?? "AG Malaysia (HQ)";
    private (string text, string css) GetUserStatus(UserDto u)
    {
        if (u.IsActive) return ("Active", "st-active");
        if (!string.IsNullOrEmpty(u.Email) && !u.LastLoginAt.HasValue) return ("Invited", "st-invited");
        return ("Inactive", "st-inactive");
    }
    private string FormatRoleName(string r) => r switch { "TenantAdmin" => "Tenant Admin", "ProductAdmin" => "Product Admin", "ITSupport" => "IT Support", _ => r };
    private string GetRoleColorClass(string r) => r switch { "TenantAdmin" => "role-admin", "ProductAdmin" => "role-product", "HR" or "HRAdmin" => "role-hr", "Finance" => "role-finance", "ITSupport" or "IT Support" => "role-it", "L&D" or "LearningAndDevelopment" => "role-ld", "Manager" or "ReportingManager" => "role-manager", _ => "role-default" };
    private static string GetInitials(string? f, string? l) { var a = f?.Trim().FirstOrDefault(); var b = l?.Trim().FirstOrDefault(); return a != default && b != default ? $"{a}{b}" : a != default ? $"{a}" : "?"; }
    private static string GetFullName(string? f, string? l) { var n = $"{f} {l}".Trim(); return string.IsNullOrEmpty(n) ? "Unnamed" : n; }
    private string GetAvatarColor(string t) { var c = new[] { "#3B82F6", "#10B981", "#8B5CF6", "#F59E0B", "#EF4444", "#EC4899", "#06B6D4" }; return c[Math.Abs(t.GetHashCode()) % c.Length]; }

    // Roles dialog
    private async Task OpenRolesDialog(UserDto user)
    {
        _selectedUser = user; _rolesTab = "roles"; _showRolesDialog = true; _loadingRoles = true; StateHasChanged();
        try { _userRoles = await Http.GetFromJsonAsync<List<UserRoleDto>>($"api/users/{user.Id}/roles") ?? new(); }
        catch { _userRoles = new(); }
        finally { _loadingRoles = false; StateHasChanged(); }
    }

    private void CloseRolesDialog() { _showRolesDialog = false; _selectedUser = null; }

    private void MoveRole(int index, int direction)
    {
        var newIndex = index + direction;
        if (newIndex < 0 || newIndex >= _userRoles.Count) return;
        (_userRoles[index], _userRoles[newIndex]) = (_userRoles[newIndex], _userRoles[index]);
        for (int i = 0; i < _userRoles.Count; i++) _userRoles[i].Priority = (i + 1) * 10;
    }

    private async Task SavePriorities()
    {
        if (_selectedUser == null) return;
        _savingPriorities = true; StateHasChanged();
        try
        {
            var payload = new { UserId = _selectedUser.Id, Priorities = _userRoles.Select((r, i) => new { UserRoleId = r.Id, Priority = (i + 1) * 10 }).ToList() };
            await Http.PutAsJsonAsync($"api/users/{_selectedUser.Id}/roles/reorder", payload);
            Snackbar.Add("Role priorities saved", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _savingPriorities = false; StateHasChanged(); }
    }

    private async Task RemoveRoleConfirmed()
    {
        if (_roleToRemove == null || _selectedUser == null) return;
        try { await Http.DeleteAsync($"api/users/{_selectedUser.Id}/roles/{_roleToRemove.Id}"); } catch { }
        _userRoles.Remove(_roleToRemove);
        for (int i = 0; i < _userRoles.Count; i++) _userRoles[i].Priority = (i + 1) * 10;
        _showRemoveRoleConfirm = false; _roleToRemove = null;
        Snackbar.Add("Role removed", Severity.Success);
    }

    // Inner types
    private class SubscribedProduct { public Guid Id { get; set; } public string Name { get; set; } = ""; }

    public class UserRoleDto
    {
        public Guid Id { get; set; }
        public Guid RoleId { get; set; }
        public string RoleName { get; set; } = "";
        public string RoleDisplayName { get; set; } = "";
        public Guid? ProductId { get; set; }
        public string? ProductName { get; set; }
        public int Priority { get; set; }
        public bool IsSystemRole { get; set; }
        public List<string> Permissions { get; set; } = new();
    }
}
