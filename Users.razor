@page "/admin/users"
@using AGOne.Shared
@layout AdminLayout
@inject IUserService UserService
@inject ISubscriptionService SubscriptionService
@inject IInvitationApiService InvitationApi
@inject ISnackbar Snackbar
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>User Management - AGOne</PageTitle>

<div class="um-page">
    <div class="um-header">
        <div>
            <h1 class="um-title">User Management</h1>
            <p class="um-subtitle">Manage user access to roles, and permissions across all product</p>
        </div>
        <div class="um-header-actions">
            <button class="um-btn-outline" @onclick="OpenBulkInvite">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                Bulk Invite
            </button>
            <button class="um-btn-primary" @onclick="GoToAssignAccess">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14" /><path d="M12 5v14" /></svg>
                Invite User
            </button>
        </div>
    </div>

    @if (_isLoading)
    {
        <div style="text-align:center;padding:60px;">
            <MudProgressCircular Indeterminate="true" />
            <p style="margin-top:12px;color:#6B7280;">Loading users...</p>
        </div>
    }
    else
    {
        <div class="um-tabs">
            <button class="um-tab @(_statusFilter == "all" ? "active" : "")" @onclick='() => { _statusFilter = "all"; _currentPage = 1; }'>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                All
            </button>
            <button class="um-tab @(_statusFilter == "active" ? "active" : "")" @onclick='() => { _statusFilter = "active"; _currentPage = 1; }'>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                Active
            </button>
            <button class="um-tab @(_statusFilter == "inactive" ? "active" : "")" @onclick='() => { _statusFilter = "inactive"; _currentPage = 1; }'>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="4.93" x2="19.07" y1="4.93" y2="19.07" /></svg>
                Inactive
            </button>
            <button class="um-tab @(_statusFilter == "invited" ? "active" : "")" @onclick='() => { _statusFilter = "invited"; _currentPage = 1; }'>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.2 8.4c.5.38.8.97.8 1.6v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V10c0-.63.3-1.22.8-1.6l8-6a2 2 0 0 1 2.4 0l8 6Z" /><path d="m22 10-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 10" /></svg>
                Invited
            </button>
        </div>

        <div class="um-pills">
            <button class="um-pill @(_selectedProductFilter == null ? "active" : "")" @onclick="() => { _selectedProductFilter = null; _currentPage = 1; }">All Product</button>
            @foreach (var product in _subscribedProducts)
            {
                <button class="um-pill @(_selectedProductFilter == product.Id ? "active" : "")" @onclick="() => { _selectedProductFilter = product.Id; _currentPage = 1; }">@product.Name</button>
            }
        </div>

        <div class="um-toolbar">
            <div class="um-search-wrap">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="um-search-icon"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" /></svg>
                <input type="text" class="um-search" placeholder="Search" @bind="_searchTerm" @bind:event="oninput" @oninput="() => _currentPage = 1" />
            </div>
            <div class="um-toolbar-right">
                <button class="um-icon-btn" title="Refresh" @onclick="RefreshUsers">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" /><path d="M3 3v5h5" /><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16" /><path d="M16 16h5v5" /></svg>
                </button>
                <button class="um-icon-btn" title="Settings">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" /><circle cx="12" cy="12" r="3" /></svg>
                </button>
            </div>
        </div>

        <div class="um-table-card">
            <div class="um-table-wrap">
                <table class="um-table">
                    <thead>
                        <tr>
                            <th class="um-th-check"><input type="checkbox" @onchange="ToggleAllSelection" /></th>
                            <th>User ID</th>
                            <th>User Name</th>
                            <th>Roles</th>
                            <th>Status</th>
                            <th>Entity</th>
                            <th class="um-th-action">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!PagedUsers.Any())
                        {
                            <tr><td colspan="7" class="um-empty-row">No users found</td></tr>
                        }
                        @foreach (var user in PagedUsers)
                        {
                            <tr @onclick="() => OpenRolesDialog(user)" style="cursor:pointer;">
                                <td class="um-td-check" @onclick:stopPropagation="true"><input type="checkbox" @bind="user.IsSelected" /></td>
                                <td class="um-td-id">@GetUserId(user)</td>
                                <td>
                                    <div class="um-user-cell">
                                        <div class="um-avatar" style="background:@GetAvatarColor(user.Email ?? user.FirstName ?? "")">@GetInitials(user.FirstName, user.LastName)</div>
                                        <div>
                                            <div class="um-user-name">@GetFullName(user.FirstName, user.LastName)</div>
                                            <div class="um-user-email">@(string.IsNullOrEmpty(user.Email) ? "No email" : user.Email)</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="um-roles">
                                        @foreach (var role in (user.Roles ?? new List<string>()).Take(3))
                                        {
                                            <span class="um-role @GetRoleColorClass(role)">@FormatRoleName(role)</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @{ var (statusText, statusClass) = GetUserStatus(user); }
                                    <span class="um-status @statusClass">@statusText</span>
                                </td>
                                <td class="um-td-entity">@GetEntity(user)</td>
                                <td class="um-td-action" @onclick:stopPropagation="true">
                                    <button class="um-action-btn" title="Assign Access" @onclick="() => GoToAssignAccessForUser(user)">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M19 8v6" /><path d="M22 11h-6" />
                                        </svg>
                                    </button>
                                    <button class="um-action-btn" title="Edit Roles" @onclick="() => OpenRolesDialog(user)">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" /><path d="m15 5 4 4" />
                                        </svg>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <div class="um-table-footer">
                <span class="um-showing">Showing @((_currentPage - 1) * _pageSize + 1) to @(Math.Min(_currentPage * _pageSize, TotalFilteredCount)) of @TotalFilteredCount entries</span>
                <div class="um-pagination">
                    <button class="um-page-btn" disabled="@(_currentPage <= 1)" @onclick="() => _currentPage--">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6" /></svg>
                    </button>
                    @for (int p = 1; p <= TotalPages; p++)
                    {
                        var pageNum = p;
                        <button class="um-page-btn @(pageNum == _currentPage ? "active" : "")" @onclick="() => _currentPage = pageNum">@pageNum</button>
                    }
                    <button class="um-page-btn" disabled="@(_currentPage >= TotalPages)" @onclick="() => _currentPage++">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6" /></svg>
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@* ═══════════════════════════════════════════════════════════════════════════ *@
@* ROLES & PERMISSIONS DIALOG — opens on row click or edit button             *@
@* ═══════════════════════════════════════════════════════════════════════════ *@
@if (_showRolesDialog && _selectedUser != null)
{
    <div class="modal-overlay" @onclick="CloseRolesDialog">
        <div class="rd-dialog" @onclick:stopPropagation="true">
            <div class="rd-header">
                <div class="rd-user-info">
                    <div class="um-avatar" style="background:@GetAvatarColor(_selectedUser.Email ?? "")">@GetInitials(_selectedUser.FirstName, _selectedUser.LastName)</div>
                    <div>
                        <h2>@GetFullName(_selectedUser.FirstName, _selectedUser.LastName)</h2>
                        <p>@(_selectedUser.Email ?? "No email") · @GetEntity(_selectedUser)</p>
                    </div>
                </div>
                <button class="close-btn" @onclick="CloseRolesDialog">&times;</button>
            </div>

            <div class="rd-tabs">
                <button class="rd-tab @(_rolesTab == "roles" ? "active" : "")" @onclick='() => _rolesTab = "roles"'>Roles & Priority</button>
                <button class="rd-tab @(_rolesTab == "permissions" ? "active" : "")" @onclick='() => _rolesTab = "permissions"'>Permissions</button>
            </div>

            <div class="rd-body">
                @if (_rolesTab == "roles")
                {
                    <div class="rd-section-header">
                        <div>
                            <h3>Assigned Roles</h3>
                            <p class="rd-hint">Use arrows to reorder. Role #1 is the primary role used at login.</p>
                        </div>
                        <button class="um-btn-primary rd-btn-sm" @onclick="() => GoToAssignAccessForUser(_selectedUser)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14" /><path d="M12 5v14" /></svg>
                            Add Role
                        </button>
                    </div>

                    @if (_loadingRoles)
                    {
                        <div style="text-align:center;padding:32px;"><MudProgressCircular Indeterminate="true" Size="Size.Small" /><p style="margin-top:8px;color:#94a3b8;font-size:13px;">Loading roles...</p></div>
                    }
                    else if (_userRoles.Count == 0)
                    {
                        <div class="rd-empty"><p>No roles assigned. Click "Add Role" to get started.</p></div>
                    }
                    else
                    {
                        <div class="rd-role-list">
                            @foreach (var (role, index) in _userRoles.Select((r, i) => (r, i)))
                            {
                                <div class="rd-role-card @(index == 0 ? "primary" : "")">
                                    <div class="rd-role-left">
                                        <div class="rd-priority @(index == 0 ? "p1" : "")">#@(index + 1)</div>
                                        <div class="rd-role-info">
                                            <div class="rd-role-name">
                                                @role.RoleDisplayName
                                                @if (index == 0) { <span class="rd-tag-primary">Primary</span> }
                                                @if (role.IsSystemRole) { <span class="rd-tag-system">System</span> }
                                            </div>
                                            <div class="rd-role-meta">
                                                <span class="um-role @(role.ProductName != null ? "role-product" : "role-admin")">@(role.ProductName ?? "Platform-wide")</span>
                                                <span class="rd-perm-count">@role.Permissions.Count permissions</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="rd-role-actions">
                                        <button class="um-icon-btn" title="Move up" disabled="@(index == 0)" @onclick="() => MoveRole(index, -1)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m18 15-6-6-6 6" /></svg>
                                        </button>
                                        <button class="um-icon-btn" title="Move down" disabled="@(index == _userRoles.Count - 1)" @onclick="() => MoveRole(index, 1)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6" /></svg>
                                        </button>
                                        @if (!role.IsSystemRole)
                                        {
                                            <button class="um-icon-btn rd-del" title="Remove" @onclick="() => { _roleToRemove = role; _showRemoveRoleConfirm = true; }">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18" /><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" /><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" /></svg>
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <div style="text-align:right;margin-top:14px;">
                            <button class="um-btn-primary rd-btn-sm" @onclick="SavePriorities" disabled="@_savingPriorities">
                                @if (_savingPriorities) { <span class="spinner"></span> }
                                Save Priority Order
                            </button>
                        </div>
                    }
                }
                else
                {
                    <div class="rd-section-header"><h3>Effective Permissions</h3><p class="rd-hint">Combined from all roles, grouped by role priority.</p></div>
                    @if (_userRoles.Count == 0)
                    {
                        <div class="rd-empty"><p>No roles — no permissions.</p></div>
                    }
                    @foreach (var role in _userRoles)
                    {
                        <div class="rd-perm-group">
                            <div class="rd-perm-header">
                                <span class="um-role @GetRoleColorClass(role.RoleName)">@role.RoleDisplayName</span>
                                @if (role.ProductName != null) { <span class="rd-perm-product">@role.ProductName</span> }
                            </div>
                            <div class="rd-perm-tags">
                                @if (role.Permissions.Count == 0) { <span class="rd-no-perm">No permissions configured</span> }
                                @foreach (var p in role.Permissions) { <span class="rd-perm-tag">@p</span> }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@* ═══ REMOVE ROLE CONFIRM ═══ *@
@if (_showRemoveRoleConfirm && _roleToRemove != null)
{
    <div class="modal-overlay" style="z-index:1100;" @onclick="() => _showRemoveRoleConfirm = false">
        <div class="modal-content" style="max-width:400px;" @onclick:stopPropagation="true">
            <div class="modal-header" style="border-bottom-color:#fecaca;"><h2 style="color:#dc2626;">Remove Role</h2><button class="close-btn" @onclick="() => _showRemoveRoleConfirm = false">&times;</button></div>
            <div class="modal-body" style="text-align:center;padding:28px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M12 8v4" /><path d="m12 16 .01 0" /></svg>
                <p style="margin:16px 0 4px;font-size:15px;">Remove <strong>@_roleToRemove.RoleDisplayName</strong>?</p>
                <p style="font-size:13px;color:#64748b;">This revokes all permissions from this role.</p>
            </div>
            <div class="modal-footer" style="justify-content:center;">
                <button class="um-btn-outline" @onclick="() => _showRemoveRoleConfirm = false">Cancel</button>
                <button class="um-btn-primary" style="background:#dc2626;" @onclick="RemoveRoleConfirmed">Remove</button>
            </div>
        </div>
    </div>
}

<style>
    .um-page { display: flex; flex-direction: column; min-height: calc(100vh - 72px); font-family: 'Inter', 'Segoe UI', sans-serif; }
    .um-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; }
    .um-title { font-size: 26px; font-weight: 800; color: #0f172a; margin: 0; }
    .um-subtitle { font-size: 14px; color: #64748b; margin: 4px 0 0; }
    .um-header-actions { display: flex; gap: 10px; }
    .um-btn-primary { display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; border: none; border-radius: 8px; background: #3b82f6; color: #fff; font-size: 14px; font-weight: 600; cursor: pointer; transition: background 0.2s; }
    .um-btn-primary:hover { background: #2563eb; }
    .um-btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
    .um-btn-outline { display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; border: 1px solid #d1d5db; border-radius: 8px; background: #fff; color: #374151; font-size: 14px; font-weight: 600; cursor: pointer; }
    .um-btn-outline:hover { background: #f9fafb; }
    .um-tabs { display: flex; gap: 0; border-bottom: 2px solid #e2e8f0; margin-bottom: 16px; }
    .um-tab { display: flex; align-items: center; gap: 6px; padding: 10px 18px; border: none; background: none; color: #64748b; font-size: 14px; font-weight: 500; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -2px; transition: all 0.2s; }
    .um-tab:hover { color: #3b82f6; }
    .um-tab.active { color: #3b82f6; border-bottom-color: #3b82f6; font-weight: 600; }
    .um-pills { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
    .um-pill { padding: 7px 16px; border: 1px solid #e2e8f0; border-radius: 8px; background: #fff; color: #475569; font-size: 13px; font-weight: 500; cursor: pointer; transition: all 0.15s; }
    .um-pill:hover { border-color: #93c5fd; color: #2563eb; }
    .um-pill.active { background: #eff6ff; color: #2563eb; border-color: #93c5fd; font-weight: 600; }
    .um-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
    .um-search-wrap { position: relative; }
    .um-search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #94a3b8; pointer-events: none; }
    .um-search { padding: 9px 14px 9px 36px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; width: 280px; background: #fff; }
    .um-search:focus { outline: none; border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,0.1); }
    .um-toolbar-right { display: flex; gap: 6px; }
    .um-icon-btn { background: #fff; border: 1px solid #d1d5db; border-radius: 8px; padding: 8px; cursor: pointer; color: #64748b; display: flex; align-items: center; }
    .um-icon-btn:hover { background: #f1f5f9; }
    .um-icon-btn:disabled { opacity: 0.3; cursor: default; }
    .um-table-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; }
    .um-table-wrap { overflow-x: auto; }
    .um-table { width: 100%; border-collapse: collapse; }
    .um-table thead { background: #3b82f6; }
    .um-table th { padding: 12px 16px; text-align: left; font-size: 12px; font-weight: 700; color: #fff; white-space: nowrap; }
    .um-table td { padding: 14px 16px; font-size: 14px; color: #0f172a; border-bottom: 1px solid #f1f5f9; }
    .um-table tbody tr:hover { background: #f8fafc; }
    .um-table tbody tr:last-child td { border-bottom: none; }
    .um-th-check, .um-td-check { width: 40px; text-align: center; }
    .um-th-check input, .um-td-check input { width: 16px; height: 16px; accent-color: #3b82f6; cursor: pointer; }
    .um-th-action { width: 90px; text-align: center; }
    .um-td-action { text-align: center; }
    .um-td-id { font-weight: 500; color: #475569; white-space: nowrap; }
    .um-td-entity { color: #475569; white-space: nowrap; }
    .um-empty-row { text-align: center; padding: 48px 16px !important; color: #94a3b8; }
    .um-user-cell { display: flex; align-items: center; gap: 12px; }
    .um-avatar { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 600; font-size: 13px; flex-shrink: 0; }
    .um-user-name { font-weight: 600; color: #0f172a; font-size: 14px; }
    .um-user-email { font-size: 12px; color: #64748b; }
    .um-roles { display: flex; gap: 6px; flex-wrap: wrap; }
    .um-role { padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 600; white-space: nowrap; }
    .um-role.role-admin { background: #dbeafe; color: #1d4ed8; }
    .um-role.role-product { background: #ede9fe; color: #6d28d9; }
    .um-role.role-hr { background: #dbeafe; color: #1e40af; }
    .um-role.role-finance { background: #e0e7ff; color: #4338ca; }
